local totalOptimized = 0
local boosterActive  = false

local function SafeSet(obj, prop, val)
    pcall(function() obj[prop] = val end)
end

local function IsType(obj, t)
    local ok, r = pcall(function() return obj:IsA(t) end)
    return ok and r
end

local function IsMobile()
    return UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
end

local function Log(msg)
    print("[UltraBooster] " .. msg)
end

-- ══════════════════════════════════════════════════════════════════
--            MODULE 1 — RENDER QUALITY (PC + Mobile)
-- ══════════════════════════════════════════════════════════════════
local function M1_RenderQuality()
    pcall(function()
        settings().Rendering.QualityLevel          = Enum.QualityLevel.Level01
        settings().Rendering.FrameRateManager      = Enum.FrameRateManagerMode.On
        settings().Rendering.EagerBulkExecution    = true
    end)
    SafeSet(Camera, "FieldOfView", Config.CameraFOV)
    Log("✅ [M1] Render Quality → Level 1 minimum")
end

-- ══════════════════════════════════════════════════════════════════
--            MODULE 2 — LIGHTING POLOS TOTAL
-- ══════════════════════════════════════════════════════════════════
local function M2_LightingPolos()
    -- Mode Compatibility = paling ringan, matikan future lighting
    pcall(function()
        Lighting.Technology = Enum.Technology.Compatibility
    end)

    SafeSet(Lighting, "GlobalShadows",  false)
    SafeSet(Lighting, "FogEnd",         1500)
    SafeSet(Lighting, "FogStart",       1400)

    -- Flat Ambient = cahaya merata, tidak ada shading gelap
    if Config.FlatAmbient then
        SafeSet(Lighting, "Ambient",        Color3.new(1, 1, 1))
        SafeSet(Lighting, "Brightness",     0)
        SafeSet(Lighting, "OutdoorAmbient", Color3.new(1, 1, 1))
    end

    -- Skybox polos
    if Config.DisableSkybox then
        local sky = Lighting:FindFirstChildOfClass("Sky")
        if sky then sky:Destroy() end
    end

    -- Atmosphere simpel
    if Config.SimplifyAtmosphere then
        local atmo = Lighting:FindFirstChildOfClass("Atmosphere")
        if atmo then
            SafeSet(atmo, "Density", 0)
            SafeSet(atmo, "Offset",  0)
            SafeSet(atmo, "Glare",   0)
            SafeSet(atmo, "Haze",    0)
        end
    end

    -- Hapus semua Post FX
    for _, fx in pairs(Lighting:GetChildren()) do
        pcall(function()
            if IsType(fx, "BloomEffect")          and Config.DisableBloom           then fx:Destroy()
            elseif IsType(fx, "BlurEffect")       and Config.DisableBlur            then fx:Destroy()
            elseif IsType(fx, "SunRaysEffect")    and Config.DisableSunRays         then fx:Destroy()
            elseif IsType(fx, "DepthOfFieldEffect") and Config.DisableDepthOfField  then fx:Destroy()
            elseif IsType(fx, "ColorCorrectionEffect") and Config.DisableColorCorrection then fx:Destroy()
            end
        end)
    end

    -- Watch lighting children baru
    Lighting.ChildAdded:Connect(function(child)
        task.defer(function()
            pcall(function()
                if IsType(child, "BloomEffect") or IsType(child, "BlurEffect")
                or IsType(child, "SunRaysEffect") or IsType(child, "DepthOfFieldEffect")
                or IsType(child, "ColorCorrectionEffect") then
                    child:Destroy()
                end
                if IsType(child, "Sky") and Config.DisableSkybox then
                    child:Destroy()
                end
            end)
        end)
    end)

    Log("✅ [M2] Lighting → Compatibility Mode, Flat Ambient, No Post FX")
end

-- ══════════════════════════════════════════════════════════════════
--            MODULE 3 — POLOS TOTAL (Tekstur & Material)
-- ══════════════════════════════════════════════════════════════════
local function M3_ApplyPolosToObject(obj)
    pcall(function()
        -- Ganti material ke SmoothPlastic
        if Config.ForceSmoothPlastic and IsType(obj, "BasePart") then
            obj.Material    = Enum.Material.SmoothPlastic
            obj.Reflectance = 0
            obj.CastShadow  = false
        end

        -- Sembunyikan Decal
        if Config.DisableDecals and IsType(obj, "Decal") then
            obj.Transparency = 1
        end

        -- Sembunyikan Texture
        if Config.DisableTextures and IsType(obj, "Texture") then
            obj.Transparency = 1
        end

        -- Mesh detail minimum
        if Config.DisableMeshDetail and IsType(obj, "SpecialMesh") then
            SafeSet(obj, "LOD", Enum.MeshPartDetailLevel.Disabled)
        end

        -- MeshPart RenderFidelity = Automatic (auto LOD)
        if IsType(obj, "MeshPart") then
            SafeSet(obj, "RenderFidelity", Enum.RenderFidelity.Automatic)
            if Config.DisableShadows then
                obj.CastShadow = false
            end
        end
    end)
end

-- ══════════════════════════════════════════════════════════════════
--            MODULE 4 — PARTIKEL & EFEK POLOS TOTAL
-- ══════════════════════════════════════════════════════════════════
local function M4_KillFXOnObject(obj)
    pcall(function()
        -- Partikel
        if IsType(obj, "ParticleEmitter") then
            obj.Enabled  = false
            obj.Rate     = 0
            obj.Lifetime = NumberRange.new(0, 0)
        end

        -- Trail
        if Config.DisableTrails and IsType(obj, "Trail") then
            obj.Enabled = false
        end

        -- Elemen alam
        if Config.DisableSmoke  and IsType(obj, "Smoke")    then obj.Enabled = false end
        if Config.DisableFire   and IsType(obj, "Fire")     then obj.Enabled = false end
        if Config.DisableSparks and IsType(obj, "Sparkles") then obj.Enabled = false end

        -- Lampu (PointLight dll bikin GPU spike saat combat)
        if Config.KillAllLights then
            if IsType(obj, "PointLight") or IsType(obj, "SpotLight") or IsType(obj, "SurfaceLight") then
                obj.Brightness = 0
                obj.Range      = 0
            end
        end

        -- Aura & Glow
        if Config.DisableAura then
            local name = (obj.Name or ""):lower()
            if name:find("aura") or name:find("glow") or name:find("shine") or name:find("effect") then
                if IsType(obj, "ParticleEmitter") then
                    obj.Enabled = false
                    obj.Rate    = 0
                elseif IsType(obj, "SelectionBox") then
                    obj:Destroy()
                elseif IsType(obj, "BillboardGui") then
                    obj.Enabled = false
                end
            end
        end

        -- SelectionBox (highlight musuh/item)
        if IsType(obj, "SelectionBox") then
            SafeSet(obj, "SurfaceTransparency", 1)
            SafeSet(obj, "LineThickness", 0)
        end
    end)
end

-- ══════════════════════════════════════════════════════════════════
--            MODULE 5 — SCAN SELURUH WORKSPACE
-- ══════════════════════════════════════════════════════════════════
local function M5_ScanWorkspace()
    local count = 0
    for _, obj in pairs(Workspace:GetDescendants()) do
        M3_ApplyPolosToObject(obj)
        M4_KillFXOnObject(obj)
        count += 1
        totalOptimized += 1

        -- Yield agar tidak freeze
        if count % Config.YieldEveryNObjects == 0 then
            task.wait()
        end
    end
    Log("✅ [M5] Workspace scan selesai — " .. count .. " objects dioptimasi")
end

-- ══════════════════════════════════════════════════════════════════
--            MODULE 6 — OCEAN & WORLD OPTIMIZER
-- ══════════════════════════════════════════════════════════════════
local function M6_WorldOptimizer()
    for _, obj in pairs(Workspace:GetDescendants()) do
        pcall(function()
            if IsType(obj, "BasePart") then
                local name = (obj.Name or ""):lower()

                -- Air/Laut
                if name:find("water") or name:find("ocean") or name:find("sea") or name:find("wave") then
                    obj.CastShadow = false
                    obj.Reflectance = 0
                    if Config.DisableWaterWave then
                        for _, c in pairs(obj:GetChildren()) do
                            if IsType(c, "SpecialMesh") then
                                SafeSet(c, "LOD", Enum.MeshPartDetailLevel.Disabled)
                            end
                        end
                    end
                end

                -- Foliage
                if Config.DisableFoliage then
                    if name:find("grass") or name:find("leaf") or name:find("bush")
                    or name:find("tree") or name:find("foliage") then
                        obj.CastShadow = false
                        obj.Material   = Enum.Material.SmoothPlastic
                    end
                end
            end
        end)
    end
    Log("✅ [M6] Ocean & World optimized")
end

-- ══════════════════════════════════════════════════════════════════
--            MODULE 7 — NPC & ENEMY OPTIMIZER
-- ══════════════════════════════════════════════════════════════════
local function M7_NPCOptimizer()
    for _, obj in pairs(Workspace:GetDescendants()) do
        pcall(function()
            if IsType(obj, "Model") then
                local humanoid = obj:FindFirstChildOfClass("Humanoid")
                if humanoid and obj ~= LocalPlayer.Character then
                    -- Shadow NPC
                    if Config.DisableNPCShadow then
                        for _, part in pairs(obj:GetDescendants()) do
                            if IsType(part, "BasePart") then
                                part.CastShadow = false
                            end
                            -- FX NPC
                            M4_KillFXOnObject(part)
                        end
                    end
                end
            end
        end)
    end
    Log("✅ [M7] NPC/Enemy optimized")
end

-- ══════════════════════════════════════════════════════════════════
--            MODULE 8 — OTHER PLAYER FX KILLER
--            (Efek jurus pemain lain yang paling berat!)
-- ══════════════════════════════════════════════════════════════════
local function M8_KillOtherPlayerFX()
    if not Config.DisableOtherPlayerFX then return end

    local function cleanPlayer(player)
        if player == LocalPlayer then return end
        if player.Character then
            for _, obj in pairs(player.Character:GetDescendants()) do
                M4_KillFXOnObject(obj)
                pcall(function()
                    if IsType(obj, "BasePart") then
                        obj.CastShadow = false
                    end
                end)
            end
        end
    end

    -- Bersihkan semua player yang sudah ada
    for _, p in pairs(Players:GetPlayers()) do
        cleanPlayer(p)
    end

    -- Watch player baru join
    Players.PlayerAdded:Connect(function(player)
        player.CharacterAdded:Connect(function(char)
            task.wait(1)
            for _, obj in pairs(char:GetDescendants()) do
                M4_KillFXOnObject(obj)
            end
            char.DescendantAdded:Connect(function(obj)
                task.defer(function()
                    M4_KillFXOnObject(obj)
                end)
            end)
        end)
    end)

    Log("✅ [M8] Other player FX killed")
end

-- ══════════════════════════════════════════════════════════════════
--            MODULE 9 — CHARACTER OPTIMIZER
-- ══════════════════════════════════════════════════════════════════
local function M9_CharacterOptimizer(character)
    if not character then return end
    task.wait(1)

    for _, obj in pairs(character:GetDescendants()) do
        pcall(function()
            -- Matikan aura/glow karakter sendiri
            if Config.DisableAura then
                local name = (obj.Name or ""):lower()
                if name:find("aura") or name:find("glow") then
                    if IsType(obj, "ParticleEmitter") then
                        obj.Rate    = 0
                        obj.Enabled = false
                    end
                end
            end
            if Config.DisableTrails and IsType(obj, "Trail") then
                obj.Enabled = false
            end
            -- Shadow karakter sendiri tetap
            if Config.DisableCharShadow and IsType(obj, "BasePart") then
                obj.CastShadow = false
            end
        end)
    end

    -- Watch objek baru pada karakter (spawn skill)
    character.DescendantAdded:Connect(function(obj)
        task.defer(function()
            M4_KillFXOnObject(obj)
        end)
    end)

    Log("✅ [M9] Character optimized")
end

