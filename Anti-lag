--  [B2] POLOS SYSTEM — SmoothPlastic ke NPC & Player
-- ══════════════════════════════════════════════════════════════════

-- ── Daftar nama NPC / accessory yang harus di-skip total ─────────
-- Tambahkan nama NPC bermasalah di sini jika masih ada error
local NPC_BLACKLIST = {
    -- ["NamaModel"] = true,
}

-- Cek apakah sebuah part adalah bagian dari efek (bukan body utama)
-- Efek seperti LightningRing, aura, dll biasanya berada di folder Effect/Container
-- atau memiliki nama yang mengandung kata kunci tertentu
local EFFECT_KEYWORDS = {
    "effect", "lightning", "aura", "ring", "container",
    "vfx", "particle", "glow", "trail", "impact",
}
local function IsEffectObject(obj)
    -- Cek nama object & semua parent-nya sampai karakter
    local current = obj
    for _ = 1, 6 do  -- maksimal 6 level ke atas
        if not current then break end
        local name = string.lower(current.Name)
        for _, kw in ipairs(EFFECT_KEYWORDS) do
            if string.find(name, kw) then return true end
        end
        local ok, p = pcall(function() return current.Parent end)
        if not ok or p == nil then break end
        current = p
    end
    return false
end

-- Terapkan polos ke satu karakter
local function PolosCharacter(character)
    if not character then return end
    if character == LocalPlayer.Character then return end

    -- Blacklist check
    local charName
    pcall(function() charName = character.Name end)
    if charName and NPC_BLACKLIST[charName] then return end

    -- Pastikan karakter masih ada
    local ok, parentVal = pcall(function() return character.Parent end)
    if not ok or parentVal == nil then return end

    -- Pastikan Humanoid masih ada & sehat
    local hum = character:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    -- Pastikan HumanoidRootPart ada — kalau tidak ada, skip (NPC sedang spawn/mati)
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- Snapshot descendants
    local descendants
    local snapOk = pcall(function() descendants = character:GetDescendants() end)
    if not snapOk or not descendants then return end

    for _, part in ipairs(descendants) do
        pcall(function()
            -- Guard: skip yang sudah di-destroy
            if part.Parent == nil then return end

            -- KRITIS: skip semua object yang berada di dalam folder efek/container
            -- Ini mencegah error LightningRing dan efek serupa
            if IsEffectObject(part) then return end

            if IsType(part, "BasePart") then
                -- Hanya sentuh shadow & material — jangan ubah ukuran/posisi/parent
                SafeSet(part, "CastShadow", false)
                -- Hanya terapkan SmoothPlastic pada part yang materialnya bukan Force Field
                -- (beberapa NPC boss punya material khusus yang tidak boleh diubah)
                local mat
                pcall(function() mat = part.Material end)
                if mat and mat ~= Enum.Material.ForceField and mat ~= Enum.Material.Neon then
                    SafeSet(part, "Material", Enum.Material.SmoothPlastic)
                end
                if Config.PolosColor then
                    SafeSet(part, "Color", Config.PolosColor)
                end

            elseif IsType(part, "Decal") or IsType(part, "Texture") then
                SafeSet(part, "Transparency", 1)

            elseif IsType(part, "ParticleEmitter") or IsType(part, "Trail")
                or IsType(part, "Sparkles") or IsType(part, "Smoke") or IsType(part, "Fire") then
                SafeSet(part, "Enabled", false)

            -- DIHAPUS: SpecialMesh TextureId — ini penyebab crash LightningRing
            -- SpecialMesh tidak disentuh sama sekali untuk menghindari konflik efek
            end
        end)
    end
end

-- Polos semua NPC di Workspace
function FPSBooster.PolosAllNPC()
    if not Config.PolosNPC then return end

    local playerChars = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then playerChars[p.Character] = true end
    end

    local all
    pcall(function() all = Workspace:GetDescendants() end)
    if not all then return end

    local count = 0
    for _, obj in ipairs(all) do
        pcall(function()
            if obj.Parent == nil then return end
            if IsType(obj, "Model")
            and obj:FindFirstChildOfClass("Humanoid")
            and not playerChars[obj] then
                PolosCharacter(obj)
                count += 1
            end
        end)
    end
    Log("POLOS", "🤖 NPC dipoloskan: " .. count)
end

-- Polos semua karakter player lain
function FPSBooster.PolosAllPlayers()
    if not Config.PolosPlayers then return end
    local count = 0
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            PolosCharacter(player.Character)
            count += 1
        end
    end
    Log("POLOS", "👤 Player dipoloskan: " .. count)
end

-- Watcher realtime untuk karakter baru
function FPSBooster.StartPolosWatcher()
    -- Hook tiap player
    local function HookPlayer(player)
        if player == LocalPlayer then return end
        if player.Character then PolosCharacter(player.Character) end
        player.CharacterAdded:Connect(function(char)
            task.wait(1.5)  -- tunggu fully replicated
            local ok, p = pcall(function() return char.Parent end)
            if ok and p ~= nil then
                PolosCharacter(char)
                Log("POLOS", "👤 Auto-polos player: " .. player.Name)
            end
        end)
    end

    for _, p in ipairs(Players:GetPlayers()) do HookPlayer(p) end
    Players.PlayerAdded:Connect(HookPlayer)

    -- Re-scan NPC berkala
    if Config.PolosNPC then
        task.spawn(function()
            while true do
                task.wait(Config.PolosScanInterval)
                FPSBooster.PolosAllNPC()
            end
        end)
    end

    -- Watcher NPC baru masuk Workspace
    Workspace.DescendantAdded:Connect(function(obj)
        pcall(function()
            if not IsType(obj, "Model") then return end
            if not obj:FindFirstChildOfClass("Humanoid") then return end

            local isPlayer = false
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Character == obj then isPlayer = true; break end
            end
            if isPlayer or not Config.PolosNPC then return end

            task.wait(1.0)  -- tunggu NPC selesai di-replicate
            local ok, parentVal = pcall(function() return obj.Parent end)
            if ok and parentVal ~= nil then
                PolosCharacter(obj)
                Log("POLOS", "🤖 Auto-polos NPC baru")
            end
        end)
    end)

    Log("POLOS", "✅ Polos watcher aktif (NPC=" .. tostring(Config.PolosNPC)
        .. " | Player=" .. tostring(Config.PolosPlayers) .. ")")
end


