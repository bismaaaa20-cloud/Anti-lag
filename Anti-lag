-- BAGIAN 5: WEAK TABLE CACHE
--=========================================================================
-- [RISIKO: AMAN]

local WeakCache = setmetatable({}, { __mode = "k" })

local function CacheData(instanceKey, data)
	WeakCache[instanceKey] = data
end

local function GetCachedData(instanceKey)
	return WeakCache[instanceKey]
end


--=========================================================================
-- BAGIAN 6: PHYSICS / COLLISION GATE
--=========================================================================
-- [RISIKO: SEDANG] -> Bisa terasa aneh kalau radius terlalu kecil.

local COLLISION_CHECK_RADIUS = 100

local function ShouldProcessPhysics(part)
	if not RootPart then return true end -- fallback aman selama character belum siap
	local dist = (part.Position - RootPart.Position).Magnitude
	return dist <= COLLISION_CHECK_RADIUS
end


--=========================================================================
-- EKSEKUSI INISIALISASI (dengan notifikasi & proteksi error)
--=========================================================================

-- Tunggu game selesai load asset dulu, kurangi race-condition.
-- PENTING: game.Loaded cuma fire SEKALI, makanya wajib dicek IsLoaded()
-- dulu, kalau tidak Wait() bisa hang selamanya kalau sudah fire duluan.
if not game:IsLoaded() then
	game.Loaded:Wait()
end

NotifyUser("FPS Booster", "Memulai optimasi FPS...", 3)

local allStepsOk = true
allStepsOk = SafeCall("LowerGraphicsQuality", function()
	RenderOptimizer:LowerGraphicsQuality()
end) and allStepsOk

allStepsOk = SafeCall("DisableHeavyLightingEffects", function()
	RenderOptimizer:DisableHeavyLightingEffects()
end) and allStepsOk

-- FlattenMaterials sekarang AKTIF otomatis, mencakup objek yang SUDAH
-- ada maupun yang BARU muncul nanti. [RISIKO: SEDANG-TINGGI] karena ini
-- mengubah tampilan visual SELURUH game secara terus-menerus, bukan cuma
-- sekali jalan - kalau ada bagian map yang sengaja pakai material/efek
-- tertentu untuk estetika, itu akan ikut dipoloskan juga.
allStepsOk = SafeCall("FlattenMaterials", function()
	RenderOptimizer:FlattenMaterials(Workspace)      -- polosin part yang sudah ada
	RenderOptimizer:WatchForNewInstances(Workspace)  -- auto-polosin part yang muncul belakangan
end) and allStepsOk

-- VFX Remover: [RISIKO: EKSTREM] - Destroy() itu PERMANEN. Kalau ada
-- script lain yang masih pegang referensi ke VFX yang sudah dihapus,
-- itu bisa error saat script itu coba mengubah propertinya lagi.
allStepsOk = SafeCall("VFXRemover", function()
	VFXRemover:RemoveExisting(Workspace)  -- hapus VFX yang sudah ada
	VFXRemover:WatchForNewVFX(Workspace)  -- auto-hapus VFX yang baru muncul
end) and allStepsOk

if allStepsOk then
	NotifyUser("FPS Booster", "Optimasi selesai! FPS kamu sekarang lebih stabil.", 4)
else
	NotifyUser("FPS Booster", "Optimasi selesai sebagian, cek Output (F9) untuk detail.", 5)
end

