local Lighting         = game:GetService("Lighting")
local Workspace        = game:GetService("Workspace")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer
local Camera      = Workspace.CurrentCamera
local PlayerGui   = LocalPlayer.PlayerGui

local function SafeSet(obj, prop, val) pcall(function() obj[prop] = val end) end
local function IsType(obj, t) local ok, r = pcall(function() return obj:IsA(t) end) return ok and r end
local function IsMobile() return UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled end
local function Log(tag, msg) print(string.format("[%s] %s", tag, msg)) end

-- ─── Config ──────────────────────────────────────────────────────
