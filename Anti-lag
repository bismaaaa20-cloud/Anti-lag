--=========================================================================
-- BAGIAN 1: PENGGANTI "GC MANIPULATION" -> ANTI-ALOKASI TABEL PER FRAME
--=========================================================================
-- [RISIKO: AMAN]
-- Karena setpause/setstepmul tidak bisa diatur di Roblox, strategi terbaik
-- adalah MENGURANGI SAMPAH yang perlu dibersihkan GC. Kita sediakan modul
-- monitor memori + fungsi util agar developer TIDAK membuat {} baru
-- setiap frame (itulah penyebab utama micro-stutter akibat GC di Roblox).

local MemoryMonitor = {}
MemoryMonitor._lastCheck = 0
MemoryMonitor._interval  = 5 -- detik, cek tiap 5 detik, jangan tiap frame

function MemoryMonitor:Check(dtNow)
	if dtNow - self._lastCheck < self._interval then return end
	self._lastCheck = dtNow

	-- collectgarbage("count") mengembalikan memori Lua terpakai dalam KB
	local memKB = collectgarbage("count")
	if memKB > 300000 then -- ambang 300 MB, sesuaikan dgn game kamu
		warn(string.format("[FPS BOOSTER] Memori Lua tinggi: %.2f MB - cek kebocoran memori!", memKB / 1024))
	end
end

-- Contoh util "reuse table" alih-alih bikin baru tiap frame:
-- SALAH:  RunService.Heartbeat:Connect(function() local t = {} ... end)
-- BENAR:  siapkan tabel sekali di luar loop, lalu clear isinya tiap frame:
local function ClearTable(t)
	for k in pairs(t) do
		t[k] = nil
	end
	return t
end


--=========================================================================
-- BAGIAN 2: RENDERING PIPELINE DOWNSCALE (Pilar 2)
--=========================================================================
-- [RISIKO: SEDANG] -> Mengubah tampilan visual game secara signifikan.
-- Beberapa properti (seperti GlobalShadows) hanya bisa diubah lewat script
-- jika kamu adalah developer game tsb (bukan exploit di game orang lain).

local RenderOptimizer = {}

function RenderOptimizer:LowerGraphicsQuality()
	-- Turunkan quality level bawaan Roblox (1-10), 1 = paling ringan
	-- Ini legal & resmi karena memakai API UserGameSettings, bukan exploit.
	pcall(function()
		UserGameSettings.SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1
	end)
end

function RenderOptimizer:DisableHeavyLightingEffects()
	-- Matikan post-processing effect berat (Bloom, Blur, DOF, SunRays, ColorCorrection)
	local heavyEffects = {"BloomEffect", "BlurEffect", "DepthOfFieldEffect", "SunRaysEffect", "ColorCorrectionEffect"}
	for _, effectName in ipairs(heavyEffects) do
		local fx = Lighting:FindFirstChildWhichIsA(effectName)
		if fx then
			fx.Enabled = false
		end
	end
	-- Matikan shadow global (drastis menaikkan FPS di device rendah)
	Lighting.GlobalShadows = false
	Lighting.FogEnd = 100000 -- fog jarak jauh dimatikan efeknya
end

function RenderOptimizer:FlattenMaterials(root)
	-- Ganti semua material berat (Neon custom, Glass, dsb) jadi SmoothPlastic
	-- HANYA jalankan sekali saat load, JANGAN di loop RenderStepped!
	for _, obj in ipairs(root:GetDescendants()) do
		if obj:IsA("BasePart") then
			obj.Material = Enum.Material.SmoothPlastic
			obj.Reflectance = 0
		elseif obj:IsA("ParticleEmitter") then
			-- Turunkan rate partikel alih-alih menghapus total (opsional, lebih aman)
			obj.Rate = obj.Rate * 0.25
		end
	end
end

-- Dynamic LOD sederhana: sembunyikan part yang jauh dari kamera
local LOD_DISTANCE = 150 -- studs
local lodTargets = {} -- cache referensi part yang mau di-LOD, isi manual/tag

local function UpdateLOD()
	local camPos = Camera.CFrame.Position
	for _, part in ipairs(lodTargets) do
		if part and part.Parent then
			local dist = (part.Position - camPos).Magnitude
			part.Transparency = (dist > LOD_DISTANCE) and 1 or 0
			-- CanCollide juga dimatikan biar physics engine gak proses part jauh
			part.CanCollide = (dist > LOD_DISTANCE) and false or part.CanCollide
		end
	end
end


--=========================================================================
-- BAGIAN 3: EVENT THROTTLING & TIMER (Pilar 4)
--=========================================================================
-- [RISIKO: AMAN]
-- JANGAN taruh logika non-visual di Heartbeat/RenderStepped mentah (60x/detik).
-- Gunakan accumulator delta-time supaya logic berjalan misal tiap 0.2 detik.

local THROTTLE_INTERVAL = 0.2 -- detik, sesuaikan kebutuhan
local _accumulator = 0

-- Cache referensi objek SEKALI di awal, jangan FindFirstChild tiap frame
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local Humanoid  = Character:WaitForChild("Humanoid")
local RootPart  = Character:WaitForChild("HumanoidRootPart")

LocalPlayer.CharacterAdded:Connect(function(newChar)
	Character = newChar
	Humanoid  = newChar:WaitForChild("Humanoid")
	RootPart  = newChar:WaitForChild("HumanoidRootPart")
end)

RunService.Heartbeat:Connect(function(dt)
	_accumulator += dt

	-- Update LOD & memory monitor TIDAK setiap frame, tapi tiap THROTTLE_INTERVAL
	if _accumulator >= THROTTLE_INTERVAL then
		_accumulator = 0
		UpdateLOD()
		MemoryMonitor:Check(os.clock())
	end
end)


--=========================================================================
-- BAGIAN 4: OBJECT POOLING FRAMEWORK (Pilar 5)
--=========================================================================
-- [RISIKO: AMAN]
-- Dipakai untuk efek yang sering muncul-hilang: peluru, hit-effect,
-- damage text, dll. Alih-alih :Destroy() lalu Instance.new() lagi
-- (mahal & bikin GC kerja keras), objek didaur ulang dari pool.

local ObjectPool = {}
ObjectPool.__index = ObjectPool

function ObjectPool.new(templateInstance, prewarmCount)
	local self = setmetatable({}, ObjectPool)
	self._template = templateInstance
	self._pool     = {} -- array-part, indeks numerik berurutan (lebih cepat drpd hash-part)
	self._active   = {}

	-- Prewarm: siapkan objek di awal biar tidak ada lag spike saat gameplay
	for i = 1, (prewarmCount or 10) do
		local clone = templateInstance:Clone()
		clone.Parent = nil -- simpan di luar Workspace dulu (tidak dirender)
		tInsert(self._pool, clone)
	end

	return self
end

function ObjectPool:Get(parent, cframe)
	local obj = tRemove(self._pool) -- ambil dari belakang (O(1), paling cepat)
	if not obj then
		-- Pool kosong -> terpaksa clone baru (jarang terjadi jika prewarm cukup)
		obj = self._template:Clone()
	end
	obj.CFrame  = cframe
	obj.Parent  = parent
	tInsert(self._active, obj)
	return obj
end

function ObjectPool:Return(obj)
	obj.Parent = nil -- "matikan" objek, JANGAN Destroy()
	for i, activeObj in ipairs(self._active) do
		if activeObj == obj then
			tRemove(self._active, i)
			break
		end
	end
	tInsert(self._pool, obj)
end

