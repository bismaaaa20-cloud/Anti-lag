local RunService       = game:GetService("RunService")
local Players          = game:GetService("Players")
local Lighting         = game:GetService("Lighting")
local Workspace        = game:GetService("Workspace")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer
local Camera      = Workspace.CurrentCamera
local PlayerGui   = LocalPlayer.PlayerGui

local function SafeSet(obj, prop, val) pcall(function() obj[prop] = val end) end
local function IsType(obj, t) local ok, r = pcall(function() return obj:IsA(t) end) return ok and r end
local function IsMobile() return UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled end
local function Log(tag, msg) print(string.format("[%s] %s", tag, msg)) end

local Config = {
    CameraFOV              = 70,
    ForceSmoothPlastic     = true,
    DisableDecals          = true,
    DisableShadows         = true,
    DisableBloom           = true,
    DisableBlur            = true,
    DisableSunRays         = true,
    DisableColorCorrection = true,
    DisableParticles       = true,
    DisableTrails          = true,
    DisableSmoke           = true,
    DisableFire            = true,
    DisableSparks          = true,
    KillLights             = true,
    DisableFog             = true,
    PolosNPC               = true,
    PolosPlayers           = true,
    PolosColor             = nil,
    PolosScanInterval      = 3.0,
    BatchSize              = 150,
    BatchDelay             = 0.03,
    WatcherQueueDelay      = 0.5,
    WatcherMaxPerTick      = 20,
}

local FPSBooster = {}

function FPSBooster.ApplyRenderAndLighting()
    pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
    SafeSet(Camera, "FieldOfView", Config.CameraFOV)
    SafeSet(Lighting, "GlobalShadows", false)
    for _, fx in pairs(Lighting:GetChildren()) do
        pcall(function()
            if Config.DisableBloom and IsType(fx, "BloomEffect") then fx:Destroy()
            elseif Config.DisableBlur and IsType(fx, "BlurEffect") then fx:Destroy()
            elseif Config.DisableSunRays and IsType(fx, "SunRaysEffect") then fx:Destroy()
            elseif Config.DisableColorCorrection and IsType(fx, "ColorCorrectionEffect") then fx:Destroy()
            end
        end)
    end
    if Config.DisableFog then
        pcall(function()
            Lighting.FogStart = 100000
            Lighting.FogEnd   = 100000
        end)
        for _, child in pairs(Lighting:GetChildren()) do
            pcall(function()
                if IsType(child, "Atmosphere") then
                    child.Density = 0
                    child.Haze    = 0
                    child.Glare   = 0
                    child.Offset  = 0
                end
            end)
        end
        Log("FPS", "Kabut dihilangkan")
    end
    Log("FPS", "Render & Lighting applied")
end

function FPSBooster.MobileBoost()
    if not IsMobile() then Log("FPS", "Mode PC"); return end
    Log("FPS", "Mode Mobile")
    pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
end

function FPSBooster.OptimizeObject(obj)
    pcall(function()
        if IsType(obj, "BasePart") then
            if Config.DisableShadows     then obj.CastShadow = false end
            if Config.ForceSmoothPlastic then obj.Material = Enum.Material.SmoothPlastic end
            return
        end
        if Config.DisableDecals and (IsType(obj, "Decal") or IsType(obj, "Texture")) then obj.Transparency = 1; return end
        if Config.DisableParticles and IsType(obj, "ParticleEmitter") then obj.Enabled = false; return end
        if Config.DisableTrails    and IsType(obj, "Trail")           then obj.Enabled = false; return end
        if Config.DisableSmoke     and IsType(obj, "Smoke")           then obj.Enabled = false; return end
        if Config.DisableFire      and IsType(obj, "Fire")            then obj.Enabled = false; return end
        if Config.DisableSparks    and IsType(obj, "Sparkles")        then obj.Enabled = false; return end
        if Config.KillLights then
            if IsType(obj, "PointLight") or IsType(obj, "SpotLight") or IsType(obj, "SurfaceLight") then
                obj.Brightness = 0
            end
        end
    end)
end

function FPSBooster.BatchScanWorkspace()
    local all = Workspace:GetDescendants()
    local total = #all
    Log("FPS", "Scan "..total.." object")
    for i = 1, total, Config.BatchSize do
        local batchEnd = math.min(i + Config.BatchSize - 1, total)
        for j = i, batchEnd do FPSBooster.OptimizeObject(all[j]) end
        task.wait(Config.BatchDelay)
    end
    Log("FPS", "Scan selesai")
end

function FPSBooster.StartThrottledWatcher()
    local watchQueue, queueSize = {}, 0
    Workspace.DescendantAdded:Connect(function(obj)
        if IsType(obj,"BasePart") or IsType(obj,"ParticleEmitter") or IsType(obj,"Trail")
        or IsType(obj,"Smoke") or IsType(obj,"Fire") or IsType(obj,"Sparkles")
        or IsType(obj,"Decal") or IsType(obj,"Texture") or IsType(obj,"PointLight") or IsType(obj,"SpotLight") then
            queueSize += 1; watchQueue[queueSize] = obj
        end
    end)
    task.spawn(function()
        while true do
            task.wait(Config.WatcherQueueDelay)
            local processed = 0
            while queueSize > 0 and processed < Config.WatcherMaxPerTick do
                local obj = watchQueue[queueSize]
                watchQueue[queueSize] = nil; queueSize -= 1
                if obj and obj.Parent then FPSBooster.OptimizeObject(obj) end
                processed += 1
            end
        end
    end)
    Log("FPS", "Watcher aktif")
end

-- POLOS SYSTEM
local BODY_PARTS = {
    HumanoidRootPart=true, Head=true, Torso=true,
    UpperTorso=true, LowerTorso=true,
    ["Left Arm"]=true,  ["Right Arm"]=true,
    ["Left Leg"]=true,  ["Right Leg"]=true,
    ["Left Hand"]=true, ["Right Hand"]=true,
    ["Left Foot"]=true, ["Right Foot"]=true,
    ["Left UpperArm"]=true,  ["Right UpperArm"]=true,
    ["Left LowerArm"]=true,  ["Right LowerArm"]=true,
    ["Left UpperLeg"]=true,  ["Right UpperLeg"]=true,
    ["Left LowerLeg"]=true,  ["Right LowerLeg"]=true,
}

local function PolosPart(part)
    pcall(function()
        if part.Parent == nil then return end
        SafeSet(part, "CastShadow", false)
        local mat
        pcall(function() mat = part.Material end)
        if mat and mat ~= Enum.Material.ForceField and mat ~= Enum.Material.Neon then
            SafeSet(part, "Material", Enum.Material.SmoothPlastic)
        end
        if Config.PolosColor then SafeSet(part, "Color", Config.PolosColor) end
        for _, child in ipairs(part:GetChildren()) do
            pcall(function()
                if IsType(child, "Decal") or IsType(child, "Texture") then
                    SafeSet(child, "Transparency", 1)
                elseif IsType(child,"ParticleEmitter") or IsType(child,"Sparkles")
                    or IsType(child,"Fire") or IsType(child,"Smoke") then
                    SafeSet(child, "Enabled", false)
                end
            end)
        end
    end)
end

local function PolosCharacter(character)
    if not character then return end
    if character == LocalPlayer.Character then return end
    local ok, parentVal = pcall(function() return character.Parent end)
    if not ok or parentVal == nil then return end
    if not character:FindFirstChildOfClass("Humanoid") then return end
    if not character:FindFirstChild("HumanoidRootPart") then return end
    local children
    pcall(function() children = character:GetChildren() end)
    if not children then return end
    for _, child in ipairs(children) do
        pcall(function()
            if child.Parent == nil then return end
            if IsType(child, "BasePart") and BODY_PARTS[child.Name] then
                PolosPart(child)
            elseif IsType(child, "Accessory") or IsType(child, "Hat") then
                local handle = child:FindFirstChild("Handle")
                if handle and IsType(handle, "BasePart") then PolosPart(handle) end
            elseif IsType(child, "Shirt") then SafeSet(child, "ShirtTemplate", "")
            elseif IsType(child, "Pants") then SafeSet(child, "PantsTemplate", "")
            elseif IsType(child, "ShirtGraphic") then SafeSet(child, "Graphic", "")
            end
        end)
    end
end

function FPSBooster.PolosAllNPC()
    if not Config.PolosNPC then return end
    local playerChars = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then playerChars[p.Character] = true end
    end
    local all
    pcall(function() all = Workspace:GetDescendants() end)
    if not all then return end
    local count = 0
    for _, obj in ipairs(all) do
        pcall(function()
            if obj.Parent == nil then return end
            if IsType(obj,"Model") and obj:FindFirstChildOfClass("Humanoid") and not playerChars[obj] then
                PolosCharacter(obj); count += 1
            end
        end)
    end
    Log("POLOS", "NPC dipoloskan: "..count)
end

function FPSBooster.PolosAllPlayers()
    if not Config.PolosPlayers then return end
    local count = 0
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            PolosCharacter(player.Character); count += 1
        end
    end
    Log("POLOS", "Player dipoloskan: "..count)
end

function FPSBooster.StartPolosWatcher()
    local function HookPlayer(player)
        if player == LocalPlayer then return end
        if player.Character then PolosCharacter(player.Character) end
        player.CharacterAdded:Connect(function(char)
            task.wait(1.5)
            local ok, p = pcall(function() return char.Parent end)
            if ok and p ~= nil then PolosCharacter(char) end
        end)
    end
    for _, p in ipairs(Players:GetPlayers()) do HookPlayer(p) end
    Players.PlayerAdded:Connect(HookPlayer)
    if Config.PolosNPC then
        task.spawn(function()
            while true do
                task.wait(Config.PolosScanInterval)
                FPSBooster.PolosAllNPC()
            end
        end)
    end
    Workspace.DescendantAdded:Connect(function(obj)
        pcall(function()
            if not IsType(obj, "Model") then return end
            if not obj:FindFirstChildOfClass("Humanoid") then return end
            local isPlayer = false
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Character == obj then isPlayer = true; break end
            end
            if isPlayer or not Config.PolosNPC then return end
            task.wait(1.0)
            local ok, parentVal = pcall(function() return obj.Parent end)
            if ok and parentVal ~= nil then PolosCharacter(obj) end
        end)
    end)
    Log("POLOS", "Polos watcher aktif")
end

-- HUD
local function CreateHUD()
    local old = PlayerGui:FindFirstChild("SafeBoosterHUD")
    if old then old:Destroy() end
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "SafeBoosterHUD"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.DisplayOrder = 999
    ScreenGui.Parent = PlayerGui
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 130, 0, 56)
    frame.Position = UDim2.new(0, 8, 0, 8)
    frame.BackgroundColor3 = Color3.fromRGB(10, 10, 18)
    frame.BackgroundTransparency = 0.25
    frame.BorderSizePixel = 0
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)
    frame.Parent = ScreenGui
    local fpsLbl = Instance.new("TextLabel")
    fpsLbl.Size = UDim2.new(1, 0, 0.5, 0)
    fpsLbl.BackgroundTransparency = 1
    fpsLbl.Text = "FPS: --"
    fpsLbl.TextColor3 = Color3.new(1, 1, 1)
    fpsLbl.Font = Enum.Font.GothamBold
    fpsLbl.TextScaled = true
    fpsLbl.Parent = frame
    local pingLbl = Instance.new("TextLabel")
    pingLbl.Size = UDim2.new(1, 0, 0.5, 0)
    pingLbl.Position = UDim2.new(0, 0, 0.5, 0)
    pingLbl.BackgroundTransparency = 1
    pingLbl.Text = "PING: --ms"
    pingLbl.TextColor3 = Color3.fromRGB(160, 200, 255)
    pingLbl.Font = Enum.Font.Gotham
    pingLbl.TextScaled = true
    pingLbl.Parent = frame
    local lastT, frames = tick(), 0
    RunService.RenderStepped:Connect(function()
        frames += 1
        local now = tick()
        if now - lastT >= 0.5 then
            fpsLbl.Text = "FPS: "..math.floor(frames / (now - lastT))
            frames, lastT = 0, now
        end
    end)
    task.spawn(function()
        while task.wait(2) do
            pcall(function()
                pingLbl.Text = "PING: "..math.floor(LocalPlayer:GetNetworkPing() * 1000).."ms"
            end)
        end
    end)
end

-- MAIN
FPSBooster.MobileBoost()
FPSBooster.ApplyRenderAndLighting()
CreateHUD()
task.spawn(function()
    task.wait(2)
    FPSBooster.BatchScanWorkspace()
    FPSBooster.StartThrottledWatcher()
    FPSBooster.PolosAllNPC()
    FPSBooster.PolosAllPlayers()
    FPSBooster.StartPolosWatcher()
    Log("SYSTEM", "SafeBooster FPS v3.0 aktif!")
end)
