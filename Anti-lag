    -- ── Sistem Tab aktif/nonaktif ─────────────────────────────────
    local pages = {
        macro = macroPage, rekaman = recPage, data = dataPage, kondisi = condPage
    }
    local tabs = {}

    local function SwitchTab(name)
        FloatingWidget._activeTab = name
        for pname, page in pairs(pages) do page.Visible = (pname == name) end
        for tname, tb in pairs(tabs) do
            tb.BackgroundColor3 = (tname == name)
                and W.PrimaryColor
                or Color3.fromRGB(40, 40, 55)
        end
    end

    -- Buat 4 tab button
    local tabNames = { "macro", "rekaman", "data", "kondisi" }
    local tabLabels = { "Makro", "Rekam", "Data", "Cond" }
    for i, tname in ipairs(tabNames) do
        local tb = MkTab(tabBar, tabLabels[i],
            UDim2.new((i-1)*0.25, (i==1 and 0 or 2), 0, 0),
            function() SwitchTab(tname) end)
        tabs[tname] = tb
    end
    SwitchTab("macro")  -- default

    -- ── Minimize / Restore ────────────────────────────────────────
    minBtn.MouseButton1Click:Connect(function()
        FloatingWidget._minimized = not FloatingWidget._minimized
        body.Visible = not FloatingWidget._minimized
        panel.Size = FloatingWidget._minimized
            and UDim2.new(0, panelW, 0, 36)
            or  UDim2.new(0, panelW, 0, panelH)
        minBtn.Text = FloatingWidget._minimized and "▲" or "─"
    end)

