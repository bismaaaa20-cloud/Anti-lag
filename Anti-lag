--[[
	=========================================================================
	 ULTIMATE FPS BOOSTER SCRIPT - ROBLOX (LUAU)  |  v3 - VFX REMOVAL
	=========================================================================
	Jenis Script : LocalScript
	Lokasi       : StarterPlayer > StarterPlayerScripts

	CATATAN PENTING:
	Roblox men-sandbox collectgarbage(). HANYA argumen "count" yang jalan;
	"collect"/"setpause"/"setstepmul" TIDAK tersedia dan akan error kalau
	dipanggil. Strategi kita: kurangi SAMPAH yang perlu di-GC (reuse table,
	object pooling, weak cache), bukan memaksa GC itu sendiri.

	PERUBAHAN v2 (STABILITAS):
	1. Notifikasi in-game saat MULAI & SELESAI (StarterGui:SetCore), bukan
	   cuma print() yang cuma kelihatan di console developer.
	2. Setiap modul dibungkus pcall lewat SafeCall() -> kalau 1 modul error
	   (misal Roblox update & ganti nama properti), modul lain tetap jalan.
	3. Loop Heartbeat dibungkus pcall per-siklus supaya 1 error tidak
	   nge-spam Output 60x/detik (yang justru bikin FPS makin turun).
	4. WaitForChild pakai timeout, jadi script tidak hang selamanya kalau
	   Character/Humanoid telat load.
	5. Referensi Camera & Character di-refresh otomatis kalau berubah
	   (respawn, kamera custom, dll), bukan cuma diambil sekali di awal.

	PERUBAHAN v3 (FITUR BARU):
	6. FlattenMaterials sekarang otomatis nyakup objek baru yang muncul
	   belakangan, plus ada audit manual _G.FPSBoosterCheckUnflatten().
	7. VFX REMOVAL (BARU): ParticleEmitter/Trail/Beam/Fire/Smoke/Sparkles
	   dihapus TOTAL (:Destroy()), termasuk yang baru spawn nanti - lihat
	   BAGIAN 2B. Explosion sengaja dikecualikan (bisa pengaruhi logic
	   damage). Tandai VFX yang mau dikecualikan dengan Attribute
	   "FPSBoosterKeep" = true di Studio.
	=========================================================================
]]

--=========================================================================
-- BAGIAN 0: SERVICE, FUNGSI, & HELPER STABILITAS
--=========================================================================

local RunService  = game:GetService("RunService")
local Players      = game:GetService("Players")
local Lighting     = game:GetService("Lighting")
local Workspace     = game:GetService("Workspace")
local StarterGui   = game:GetService("StarterGui")

local LocalPlayer = Players.LocalPlayer

-- Cache fungsi tabel yang sering dipakai
local tInsert = table.insert
local tRemove = table.remove

-- UserGameSettings bisa gagal diambil di konteks non-standar, jadi dibungkus pcall
local UserGameSettings
do
	local ok, result = pcall(function()
		return UserSettings():GetService("UserGameSettings")
	end)
	UserGameSettings = ok and result or nil
end

-- SafeCall: pembungkus pcall generik, dipakai untuk semua langkah modul.
-- Kalau fn() error, modul itu di-skip dan dicatat lewat warn(), TAPI
-- modul lain sesudahnya tetap dieksekusi (script tidak berhenti total).
local function SafeCall(moduleName, fn)
	local ok, err = pcall(fn)
	if not ok then
		warn(string.format("[FPS BOOSTER] Modul '%s' gagal: %s", moduleName, tostring(err)))
	end
	return ok
end

-- NotifyUser: notifikasi native Roblox (muncul di pojok kanan atas layar).
-- Kalau fitur notifikasi core dimatikan developer game / tidak didukung
-- platform, otomatis fallback ke print() supaya tidak error.
local function NotifyUser(title, text, duration)
	local ok = pcall(function()
		StarterGui:SetCore("SendNotification", {
			Title    = title,
			Text     = text,
			Duration = duration or 4,
		})
	end)
	if not ok then
		print(string.format("[FPS BOOSTER] %s - %s", title, text))
	end
end

print("[FPS BOOSTER] Modul optimasi dimuat, menunggu game siap...")


--=========================================================================
-- BAGIAN 1: MEMORY MONITOR (pengganti GC manipulation yang tak tersedia)
--=========================================================================
-- [RISIKO: AMAN]

local MemoryMonitor = {}
MemoryMonitor._lastCheck = 0
MemoryMonitor._interval  = 5 -- detik, jangan cek tiap frame, cukup tiap 5 detik

function MemoryMonitor:Check(dtNow)
	if dtNow - self._lastCheck < self._interval then return end
	self._lastCheck = dtNow

	local memKB = collectgarbage("count")
	if memKB > 300000 then -- ambang 300 MB, sesuaikan dgn kebutuhan game kamu
		warn(string.format("[FPS BOOSTER] Memori Lua tinggi: %.2f MB - cek kebocoran memori!", memKB / 1024))
	end
end

-- Util reuse-table: clear isi tabel lama alih-alih bikin {} baru tiap frame
local function ClearTable(t)
	for k in pairs(t) do
		t[k] = nil
	end
	return t
end


--=========================================================================
-- BAGIAN 2: RENDERING PIPELINE DOWNSCALE
--=========================================================================
-- [RISIKO: SEDANG] -> Mengubah tampilan visual game secara signifikan.

local RenderOptimizer = {}

function RenderOptimizer:LowerGraphicsQuality()
	if not UserGameSettings then
		warn("[FPS BOOSTER] UserGameSettings tidak tersedia, skip quality downscale.")
		return
	end
	UserGameSettings.SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1
end

function RenderOptimizer:DisableHeavyLightingEffects()
	local heavyEffects = {"BloomEffect", "BlurEffect", "DepthOfFieldEffect", "SunRaysEffect", "ColorCorrectionEffect"}
	for _, effectName in ipairs(heavyEffects) do
		local fx = Lighting:FindFirstChildWhichIsA(effectName)
		if fx then
			fx.Enabled = false
		end
	end
	Lighting.GlobalShadows = false
	Lighting.FogEnd = 100000
end

-- Registry pelacak objek yang SUDAH dipoloskan (weak table, jadi kalau
-- objeknya di-Destroy, entry-nya otomatis lenyap & gak nahan memori).
-- Ini juga yang bikin kita bisa CEK objek mana yang belum diproses,
-- tanpa harus menebak-nebak.
local FlattenedRegistry = setmetatable({}, { __mode = "k" })

local function FlattenInstance(obj)
	if FlattenedRegistry[obj] then return end -- sudah pernah diproses, skip

	-- CATATAN: ParticleEmitter sengaja TIDAK ditangani di sini lagi -
	-- sekarang dia (+ Trail/Beam/Fire/Smoke/Sparkles) dihapus TOTAL oleh
	-- modul VFX Removal di BAGIAN 2B, jadi gak diproses dua kali dengan
	-- cara yang beda-beda.
	if obj:IsA("BasePart") then
		obj.Material    = Enum.Material.SmoothPlastic
		obj.Reflectance = 0
		FlattenedRegistry[obj] = true
	end
end

function RenderOptimizer:FlattenMaterials(root)
	-- Tahap 1: polosin semua objek yang SUDAH ADA di scene sekarang.
	-- HANYA jalankan sekali saat load (bukan di loop per-frame!) karena
	-- GetDescendants() men-scan seluruh isi root, cukup berat kalau sering.
	for _, obj in ipairs(root:GetDescendants()) do
		FlattenInstance(obj)
	end
end

function RenderOptimizer:WatchForNewInstances(root)
	-- Tahap 2: pantau objek yang BARU MUNCUL setelah ini (senjata yang
	-- di-spawn, efek hit, proyektil, part yang di-clone runtime, dll)
	-- dan otomatis dipoloskan begitu muncul di scene.
	-- task.defer dipakai supaya script LAIN yang men-spawn objek ini
	-- sempat selesai men-setup properti-nya dulu, baru kita timpa -
	-- kalau langsung tanpa defer, kita bisa "menang duluan" sebelum
	-- objeknya selesai di-configure oleh script yang men-spawn-nya.
	root.DescendantAdded:Connect(function(obj)
		task.defer(FlattenInstance, obj)
	end)
end

function RenderOptimizer:CheckUnflattened(root)
	-- Audit: cek TEMPAT/PATH mana saja yang BELUM dipoloskan.
	-- Bisa dipanggil kapan saja lewat _G.FPSBoosterCheckUnflatten()
	-- di Command Bar Studio buat verifikasi manual.
	local missed = {}
	for _, obj in ipairs(root:GetDescendants()) do
		if obj:IsA("BasePart") and not FlattenedRegistry[obj] then
			tInsert(missed, obj:GetFullName())
		end
	end

	if #missed == 0 then
		print("[FPS BOOSTER] Semua part sudah polos 100%, tidak ada yang terlewat.")
	else
		warn(string.format("[FPS BOOSTER] %d part BELUM dipoloskan, ini daftar tempatnya:", #missed))
		for i = 1, math.min(#missed, 20) do
			print("  - " .. missed[i])
		end
		if #missed > 20 then
			print(string.format("  ...dan %d part lainnya (dipotong biar Output gak banjir)", #missed - 20))
		end
	end

	return missed
end

-- Dynamic LOD: sembunyikan/collapse part yang jauh dari kamera
local LOD_DISTANCE = 150 -- studs
local lodTargets = {} -- isi manual dengan part yang mau di-LOD

-- Camera di-refresh otomatis kalau berubah (bukan diambil sekali & dilupakan)
local Camera = Workspace.CurrentCamera
Workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
	Camera = Workspace.CurrentCamera
end)

local function UpdateLOD()
	if not Camera then return end
	local camPos = Camera.CFrame.Position
	for _, part in ipairs(lodTargets) do
		if part and part.Parent then
			local dist = (part.Position - camPos).Magnitude
			local isFar = dist > LOD_DISTANCE
			part.Transparency = isFar and 1 or 0
			part.CanCollide    = isFar and false or part.CanCollide
		end
	end
end


--=========================================================================
-- BAGIAN 2B: VFX REMOVER (HAPUS PERMANEN)
--=========================================================================
-- [RISIKO: EKSTREM] -> :Destroy() itu PERMANEN, beda dengan FlattenMaterials
-- yang cuma UBAH properti. Kalau ada script lain (buatan sendiri atau
-- bawaan game) yang masih pegang referensi ke VFX ini dan nanti coba
-- ubah propertinya, itu akan ERROR karena objeknya sudah tidak ada.
-- Kalau mau opsi yang lebih aman & bisa dibalik, ganti obj:Destroy()
-- di bawah jadi obj.Enabled = false (cek dulu class-nya punya properti
-- Enabled atau tidak, tidak semua VFX class punya).

local VFX_CLASSES_TO_REMOVE = {
	"ParticleEmitter",
	"Trail",
	"Beam",
	"Fire",
	"Smoke",
	"Sparkles",
	-- "Explosion" SENGAJA tidak dimasukkan: Explosion di Roblox sering
	-- nyambung ke logika damage/ledakan gameplay (bukan cuma visual),
	-- jadi menghapusnya bisa memutus damage sebelum sempat diproses.
	-- Tambahkan manual HANYA kalau yakin Explosion di game kamu murni
	-- kosmetik dan tidak dipakai untuk hitung damage.
}

-- Lookup table (hash-part) -> pengecekan class match jadi O(1), konsisten
-- dengan prinsip micro-optimization: hindari loop array di tiap objek.
local VFXLookup = {}
for _, className in ipairs(VFX_CLASSES_TO_REMOVE) do
	VFXLookup[className] = true
end

local VFXRemover = {}
VFXRemover._removedCount = 0

local function TryRemoveVFX(obj)
	if not VFXLookup[obj.ClassName] then return false end

	-- Pengecualian manual: developer bisa kasih Attribute
	-- "FPSBoosterKeep" = true lewat panel Properties/Attributes di Studio
	-- pada VFX tertentu yang PENTING buat gameplay (misal indikator
	-- ability aktif), supaya VFX itu tidak ikut dihapus.
	if obj:GetAttribute("FPSBoosterKeep") == true then
		return false
	end

	obj:Destroy()
	VFXRemover._removedCount += 1
	return true
end

function VFXRemover:RemoveExisting(root)
	-- Tahap 1: hapus semua VFX yang SUDAH ADA di scene sekarang.
	-- Ambil snapshot list dulu (GetDescendants), baru loop -> supaya
	-- list-nya tidak berantakan gara-gara kita Destroy() objek di
	-- tengah proses iterasi.
	local targets = root:GetDescendants()
	for _, obj in ipairs(targets) do
		TryRemoveVFX(obj)
	end
end

function VFXRemover:WatchForNewVFX(root)
	-- Tahap 2: pantau VFX yang BARU MUNCUL nanti (efek tembakan, hit
	-- effect, jejak peluru, dll) dan LANGSUNG dihapus begitu muncul -
	-- TANPA task.defer (beda dengan FlattenMaterials), karena ClassName
	-- sudah pasti sejak objek dibuat, jadi tidak perlu nunggu script lain
	-- selesai setup properti dulu. Tujuannya mencegat VFX SEBELUM sempat
	-- render walau cuma 1 frame.
	root.DescendantAdded:Connect(function(obj)
		TryRemoveVFX(obj)
	end)
end

function VFXRemover:GetRemovedCount()
	return self._removedCount
end

function VFXRemover:CheckRemaining(root)
	-- Audit: cek TEMPAT mana saja yang masih ada VFX-nya. Harusnya 0,
	-- KECUALI yang sengaja ditandai FPSBoosterKeep. Kalau ada class VFX
	-- lain di luar VFX_CLASSES_TO_REMOVE yang lolos, itu juga bakal
	-- kelihatan di sini (tanda perlu ditambahkan ke daftar).
	-- Panggil kapan saja lewat _G.FPSBoosterCheckVFX()
	local remaining = {}
	for _, obj in ipairs(root:GetDescendants()) do
		if VFXLookup[obj.ClassName] then
			tInsert(remaining, obj:GetFullName() .. " (" .. obj.ClassName .. ")")
		end
	end

	if #remaining == 0 then
		print("[FPS BOOSTER] Tidak ada VFX tersisa di luar yang ditandai FPSBoosterKeep.")
	else
		warn(string.format("[FPS BOOSTER] %d VFX masih ada (FPSBoosterKeep atau class di luar daftar):", #remaining))
		for i = 1, math.min(#remaining, 20) do
			print("  - " .. remaining[i])
		end
		if #remaining > 20 then
			print(string.format("  ...dan %d lainnya", #remaining - 20))
		end
	end

	return remaining
end


--=========================================================================
-- BAGIAN 3: KARAKTER, THROTTLING & TIMER
--=========================================================================
-- [RISIKO: AMAN]

local Character, Humanoid, RootPart

local function BindCharacter(char)
	Character = char
	-- WaitForChild dengan timeout 10 detik -> tidak nge-hang selamanya
	Humanoid = char:WaitForChild("Humanoid", 10)
	RootPart = char:WaitForChild("HumanoidRootPart", 10)
	if not Humanoid or not RootPart then
		warn("[FPS BOOSTER] Humanoid/HumanoidRootPart tidak ditemukan tepat waktu, fitur LOD/Physics-gate nonaktif sementara.")
	end
end

if LocalPlayer.Character then
	task.spawn(BindCharacter, LocalPlayer.Character)
end
LocalPlayer.CharacterAdded:Connect(function(char)
	task.spawn(BindCharacter, char)
end)

local THROTTLE_INTERVAL = 0.2 -- detik
local _accumulator = 0

RunService.Heartbeat:Connect(function(dt)
	_accumulator += dt
	if _accumulator >= THROTTLE_INTERVAL then
		_accumulator = 0
		-- Dibungkus pcall supaya 1 error tidak spam Output 60x/detik
		local ok, err = pcall(function()
			UpdateLOD()
			MemoryMonitor:Check(os.clock())
		end)
		if not ok then
			warn("[FPS BOOSTER] Error di loop optimasi: " .. tostring(err))
		end
	end
end)


--=========================================================================
-- BAGIAN 4: OBJECT POOLING FRAMEWORK
--=========================================================================
-- [RISIKO: AMAN]

local ObjectPool = {}
ObjectPool.__index = ObjectPool

function ObjectPool.new(templateInstance, prewarmCount)
	local self = setmetatable({}, ObjectPool)
	self._template = templateInstance
	self._pool     = {}
	self._active   = {}

	for _ = 1, (prewarmCount or 10) do
		local clone = templateInstance:Clone()
		clone.Parent = nil
		tInsert(self._pool, clone)
	end

	return self
end

function ObjectPool:Get(parent, cframe)
	local obj = tRemove(self._pool)
	if not obj then
		obj = self._template:Clone()
	end
	obj.CFrame = cframe
	obj.Parent = parent
	tInsert(self._active, obj)
	return obj
end

function ObjectPool:Return(obj)
	obj.Parent = nil
	for i, activeObj in ipairs(self._active) do
		if activeObj == obj then
			tRemove(self._active, i)
			break
		end
	end
	tInsert(self._pool, obj)
end

