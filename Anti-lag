local nodeIndexCounter = 0
local graphNodes = { FPS = {}, PING = {}, RAM = {}, CPU = {} }

local function PushNode(scroller, ratio, color, componentKey)
	if not scroller or not scroller:IsDescendantOf(game) then return end
	nodeIndexCounter = (nodeIndexCounter % 10000) + 1
	
	local bar = Instance.new("Frame")
	bar.Name = string.format("Node_%05d", nodeIndexCounter)
	bar.Size = UDim2.new(0, 2, ratio, 0)
	bar.BackgroundColor3 = color
	bar.BorderSizePixel = 0
	bar.LayoutOrder = nodeIndexCounter
	bar.ZIndex = 54
	bar.Parent = scroller
	
	table.insert(graphNodes[componentKey], bar)
	if #graphNodes[componentKey] > 65 then
		local oldestBar = table.remove(graphNodes[componentKey], 1)
		if oldestBar and oldestBar.Parent then oldestBar:Destroy() end
	end
end

