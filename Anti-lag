--=========================================================================
-- BAGIAN 5: WEAK TABLES UNTUK CACHE (Pilar 6)
--=========================================================================
-- [RISIKO: AMAN]
-- Dipakai untuk cache referensi objek (misal data per-Player atau per-Part)
-- supaya kalau objek aslinya sudah dihancurkan game, cache-nya otomatis
-- ikut "dilupakan" GC dan tidak menahan memori selamanya (mencegah leak).

local WeakCache = setmetatable({}, { __mode = "k" })
-- __mode = "k" -> key dalam tabel ini adalah weak reference
-- Artinya kalau instance Part/Player di-Destroy, entry ini otomatis
-- hilang dari WeakCache saat GC jalan, TANPA perlu kita hapus manual.

local function CacheData(instanceKey, data)
	WeakCache[instanceKey] = data
end

local function GetCachedData(instanceKey)
	return WeakCache[instanceKey]
end


--=========================================================================
-- BAGIAN 6: PHYSICS / COLLISION TWEAK (Pilar 7)
--=========================================================================
-- [RISIKO: SEDANG] -> Bisa mengubah rasa gameplay jika radius terlalu kecil.
-- Batasi collision check hanya untuk part yang dekat pemain.

local COLLISION_CHECK_RADIUS = 100

local function ShouldProcessPhysics(part)
	if not RootPart then return true end
	local dist = (part.Position - RootPart.Position).Magnitude
	return dist <= COLLISION_CHECK_RADIUS
end
-- Pakai ShouldProcessPhysics(part) sebagai gate sebelum raycasting manual/
-- custom collision logic kamu, supaya part jauh tidak ikut dihitung.


