                task.spawn(FPSBooster.PolosAllPlayers)
            end
            return Config.PolosPlayers
        end)

    -- Toggle: Hilangkan Kabut
    MkToggle(macroPage,
        "No-Fog: ON", "No-Fog: OFF", 264,
        function() return Config.DisableFog end,
        function()
            Config.DisableFog = not Config.DisableFog
            if Config.DisableFog then
                -- Terapkan ulang no-fog
                pcall(function()
                    Lighting.FogStart = 100000
                    Lighting.FogEnd   = 100000
                    for _, child in pairs(Lighting:GetChildren()) do
                        if IsType(child, "Atmosphere") then
                            child.Density = 0
                            child.Haze    = 0
                            child.Glare   = 0
                            child.Offset  = 0
                        end
                    end
                end)
                Log("WIDGET", "🌫️ Kabut dinonaktifkan")
            else
                -- Kembalikan fog ke nilai default Roblox
                pcall(function()
                    Lighting.FogStart = 0
                    Lighting.FogEnd   = 100000
