    local pingLbl = MkLabel(hudFrame, "PING: --ms", UDim2.new(1,0,0.5,0), UDim2.new(0,0,0.5,0),
        Color3.fromRGB(180,200,255), W.FontBody)

    local lastT, frames = tick(), 0
    RunService.RenderStepped:Connect(function()
        frames += 1
        local now = tick()
        if now - lastT >= 0.5 then
            fpsLbl.Text = "FPS: " .. math.floor(frames / (now - lastT))
            frames, lastT = 0, now
        end
    end)
    task.spawn(function()
        while task.wait(2) do
            pcall(function()
                pingLbl.Text = "PING: " .. math.floor(LocalPlayer:GetNetworkPing() * 1000) .. "ms"
            end)
        end
    end)

    FloatingWidget._gui = ScreenGui
    Log("WIDGET", "✅ Floating widget aktif (" .. (isMobile and "Mobile" or "PC") .. ")")
