-- ══════════════════════════════════════════════════════════════════
--  [B] FPS BOOSTER — (Arsitektur asli, dipertahankan penuh)
-- ══════════════════════════════════════════════════════════════════

local FPSBooster = {}

function FPSBooster.ApplyRenderAndLighting()
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)
    SafeSet(Camera, "FieldOfView", Config.CameraFOV)
    SafeSet(Lighting, "GlobalShadows", false)

    -- ── Hilangkan Kabut (Fog) ────────────────────────────────────
    if Config.DisableFog then
        pcall(function()
            Lighting.FogStart  = 100000   -- dorong batas mulai kabut sangat jauh
            Lighting.FogEnd    = 100000   -- dorong batas akhir kabut sangat jauh
            Lighting.FogColor  = Color3.fromRGB(128, 128, 128)  -- netral (tidak mempengaruhi warna)
        end)
        -- Hapus juga jika ada object Atmosphere (kabut volumetrik Roblox modern)
        for _, child in pairs(Lighting:GetChildren()) do
            pcall(function()
                if IsType(child, "Atmosphere") then
                    child.Density   = 0      -- kepadatan = 0 (transparan total)
                    child.Offset    = 0
                    child.Haze      = 0
                    child.Glare     = 0
                    child.Decay     = Color3.fromRGB(255, 255, 255)
                end
            end)
        end
        Log("FPS", "🌫️ Kabut (Fog + Atmosphere) dihilangkan")
    end

    for _, fx in pairs(Lighting:GetChildren()) do
        pcall(function()
            if Config.DisableBloom and IsType(fx, "BloomEffect") then fx:Destroy()
            elseif Config.DisableBlur and IsType(fx, "BlurEffect") then fx:Destroy()
            elseif Config.DisableSunRays and IsType(fx, "SunRaysEffect") then fx:Destroy()
            elseif Config.DisableColorCorrection and IsType(fx, "ColorCorrectionEffect") then fx:Destroy()
            end
        end)
    end
    Log("FPS", "✅ Render & Lighting applied")
end

function FPSBooster.OptimizeObject(obj)
    pcall(function()
        if IsType(obj, "BasePart") then
            if Config.DisableShadows then obj.CastShadow = false end
            if Config.ForceSmoothPlastic then obj.Material = Enum.Material.SmoothPlastic end
            return
        end
        if Config.DisableDecals and (IsType(obj, "Decal") or IsType(obj, "Texture")) then
            obj.Transparency = 1; return
        end
        if Config.DisableParticles and IsType(obj, "ParticleEmitter") then obj.Enabled = false; return end
        if Config.DisableTrails and IsType(obj, "Trail") then obj.Enabled = false; return end
        if Config.DisableSmoke and IsType(obj, "Smoke") then obj.Enabled = false; return end
        if Config.DisableFire and IsType(obj, "Fire") then obj.Enabled = false; return end
        if Config.DisableSparks and IsType(obj, "Sparkles") then obj.Enabled = false; return end
        if Config.KillLights then
            if IsType(obj, "PointLight") or IsType(obj, "SpotLight") or IsType(obj, "SurfaceLight") then
                obj.Brightness = 0
            end
        end
    end)
end

function FPSBooster.BatchScanWorkspace()
    local all = Workspace:GetDescendants()
    local total = #all
    Log("FPS", "🔍 Scan " .. total .. " object (batch mode)")
    for i = 1, total, Config.BatchSize do
        local batchEnd = math.min(i + Config.BatchSize - 1, total)
        for j = i, batchEnd do FPSBooster.OptimizeObject(all[j]) end
        task.wait(Config.BatchDelay)
    end
    Log("FPS", "✅ Scan selesai: " .. total .. " object dioptimasi")
end

function FPSBooster.StartThrottledWatcher()
    local watchQueue, queueSize = {}, 0
    Workspace.DescendantAdded:Connect(function(obj)
        if IsType(obj, "BasePart") or IsType(obj, "ParticleEmitter") or IsType(obj, "Trail")
        or IsType(obj, "Smoke") or IsType(obj, "Fire") or IsType(obj, "Sparkles")
        or IsType(obj, "Decal") or IsType(obj, "Texture") or IsType(obj, "PointLight")
        or IsType(obj, "SpotLight") then
            queueSize += 1; watchQueue[queueSize] = obj
        end
    end)
    task.spawn(function()
        while true do
            task.wait(Config.WatcherQueueDelay)
            local processed = 0
            while queueSize > 0 and processed < Config.WatcherMaxPerTick do
                local obj = watchQueue[queueSize]
                watchQueue[queueSize] = nil; queueSize -= 1
                if obj and obj.Parent then FPSBooster.OptimizeObject(obj) end
                processed += 1
            end
        end
    end)
    Log("FPS", "✅ Throttled watcher aktif")
end

function FPSBooster.MobileBoost()
    if not IsMobile() then Log("FPS", "🖥️ Mode PC terdeteksi"); return end
    Log("FPS", "📱 Mode Mobile — boost ringan diterapkan")
    pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
end

-- ══════════════════════════════════════════════════════════════════
--  [B2] POLOS CHARACTER — NPC & Player (SmoothPlastic + No Texture)
-- ══════════════════════════════════════════════════════════════════
--[[
  "Polos" berarti:
  - Material seluruh BasePart karakter → SmoothPlastic
  - Decal / Texture di karakter → Transparency = 1 (hilang)
  - Aksesoris (Hat, Shirt, Pants, dll) tetap ada modelnya tapi polos
  - Warna bisa dipertahankan asli (PolosColor = nil) atau diseragamkan
  - Khusus karakter LocalPlayer TIDAK diubah (hanya NPC & player lain)
--]]

-- Terapkan efek polos ke satu karakter (Model dengan Humanoid)
local function PolosCharacter(character)
    if not character then return end
    -- Jangan ubah karakter sendiri jika tidak dikehendaki
    if character == LocalPlayer.Character then return end

    pcall(function()
        for _, part in ipairs(character:GetDescendants()) do
            pcall(function()
                if IsType(part, "BasePart") then
                    part.Material  = Enum.Material.SmoothPlastic
                    part.CastShadow = false
                    if Config.PolosColor then
                        part.Color = Config.PolosColor
                    end
                elseif IsType(part, "Decal") or IsType(part, "Texture") then
                    part.Transparency = 1
                elseif IsType(part, "ParticleEmitter") or IsType(part, "Trail")
                    or IsType(part, "Sparkles") or IsType(part, "Smoke") or IsType(part, "Fire") then
                    part.Enabled = false
                elseif IsType(part, "SpecialMesh") then
                    -- Pertahankan bentuk mesh (kepala, badan) tapi hapus texture-nya
                    part.TextureId = ""
                end
            end)
        end
    end)
end

-- Polos semua NPC (karakter di Workspace yang bukan player)
function FPSBooster.PolosAllNPC()
    if not Config.PolosNPC then return end
    local playerChars = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then playerChars[p.Character] = true end
    end

    local count = 0
    for _, obj in ipairs(Workspace:GetDescendants()) do
        pcall(function()
            if IsType(obj, "Model") and obj:FindFirstChildOfClass("Humanoid")
            and not playerChars[obj] then
                PolosCharacter(obj)
                count += 1
            end
        end)
    end
    Log("POLOS", "🤖 NPC dipoloskan: " .. count .. " karakter")
end

-- Polos semua karakter player lain (bukan LocalPlayer)
function FPSBooster.PolosAllPlayers()
    if not Config.PolosPlayers then return end
    local count = 0
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            PolosCharacter(player.Character)
            count += 1
        end
    end
    Log("POLOS", "👤 Player lain dipoloskan: " .. count .. " karakter")
end

-- Watcher realtime: setiap player baru / karakter baru di-polos otomatis
function FPSBooster.StartPolosWatcher()
    -- Hook setiap player yang sudah ada & yang bergabung nanti
    local function HookPlayer(player)
        if player == LocalPlayer then return end
        -- Karakter sudah ada sekarang
        if player.Character then
            PolosCharacter(player.Character)
        end
        -- Karakter yang respawn nanti
        player.CharacterAdded:Connect(function(char)
            task.wait(0.5)  -- tunggu karakter fully load
            PolosCharacter(char)
            Log("POLOS", "👤 Auto-polos: " .. player.Name)
        end)
    end

    for _, p in ipairs(Players:GetPlayers()) do HookPlayer(p) end
    Players.PlayerAdded:Connect(HookPlayer)

    -- Re-scan NPC berkala (untuk NPC yang spawn terlambat)
    if Config.PolosNPC then
        task.spawn(function()
            while true do
                task.wait(Config.PolosScanInterval)
                FPSBooster.PolosAllNPC()
            end
        end)
    end

    -- Watcher DescendantAdded untuk NPC baru
    Workspace.DescendantAdded:Connect(function(obj)
        pcall(function()
            if IsType(obj, "Model") and obj:FindFirstChildOfClass("Humanoid") then
                -- Cek apakah ini NPC (bukan player)
                local isPlayer = false
                for _, p in ipairs(Players:GetPlayers()) do
                    if p.Character == obj then isPlayer = true; break end
                end
                if not isPlayer and Config.PolosNPC then
                    task.wait(0.3)
                    PolosCharacter(obj)
                end
            end
        end)
    end)

    Log("POLOS", "✅ Polos watcher aktif (NPC=" .. tostring(Config.PolosNPC)
        .. " | Player=" .. tostring(Config.PolosPlayers) .. ")")
end


-- ══════════════════════════════════════════════════════════════════
--  [C] ACTION RECORDER — Merekam urutan aksi input pengguna
-- ══════════════════════════════════════════════════════════════════
--[[
  FORMAT AKSI YANG DIREKAM:
  {
    type     = "click" | "key" | "text" | "delay" | "drag" | "scroll",
    t        = timestamp_ms,              -- waktu relatif sejak mulai rekaman
    -- untuk click/drag:
    x        = number,                    -- posisi X layar (pixel)
    y        = number,                    -- posisi Y layar (pixel)
    x2       = number,                    -- target X (drag saja)
    y2       = number,                    -- target Y (drag saja)
    button   = "Left"|"Right"|"Middle",
    -- untuk key:
    key      = Enum.KeyCode,
    mod      = { shift=bool, ctrl=bool, alt=bool },
    -- untuk text (keystroke batch):
    text     = string,
    -- untuk delay eksplisit:
    duration = number,                    -- ms
    -- untuk scroll:
    delta    = number,                    -- positif = atas, negatif = bawah
  }
--]]

local ActionRecorder = {}
ActionRecorder._recording  = false
ActionRecorder._actions    = {}
ActionRecorder._startTime  = 0
ActionRecorder._connections = {}
ActionRecorder._textBuffer = ""

-- Mulai merekam
function ActionRecorder.Start()
    if ActionRecorder._recording then
        Log("RECORDER", "⚠️ Sedang merekam — hentikan dulu sebelum mulai baru")
        return false
    end
    ActionRecorder._recording = true
    ActionRecorder._actions   = {}
    ActionRecorder._startTime = Timestamp()
    ActionRecorder._textBuffer = ""

    local function rel() return Timestamp() - ActionRecorder._startTime end

    -- ── Rekam klik mouse/touch ──────────────────────────────────
    local connInput = UserInputService.InputBegan:Connect(function(input, gpe)
        if not ActionRecorder._recording then return end
        local pos = input.Position  -- Vector3: X, Y, Z=0 untuk 2D

        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.MouseButton2
        or input.UserInputType == Enum.UserInputType.MouseButton3 then
            local btnMap = {
                [Enum.UserInputType.MouseButton1] = "Left",
                [Enum.UserInputType.MouseButton2] = "Right",
                [Enum.UserInputType.MouseButton3] = "Middle",
            }
            table.insert(ActionRecorder._actions, {
                type   = "click",
                t      = rel(),
                x      = pos.X,
                y      = pos.Y,
                button = btnMap[input.UserInputType] or "Left",
            })

        elseif input.UserInputType == Enum.UserInputType.Touch then
            -- Rekam tap sentuhan di mobile
            table.insert(ActionRecorder._actions, {
                type   = "click",
                t      = rel(),
                x      = pos.X,
                y      = pos.Y,
                button = "Touch",
            })

        elseif input.UserInputType == Enum.UserInputType.Keyboard then
            -- Rekam keystroke individu
            local mod = {
                shift = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) or UserInputService:IsKeyDown(Enum.KeyCode.RightShift),
                ctrl  = UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) or UserInputService:IsKeyDown(Enum.KeyCode.RightControl),
                alt   = UserInputService:IsKeyDown(Enum.KeyCode.LeftAlt) or UserInputService:IsKeyDown(Enum.KeyCode.RightAlt),
            }
            table.insert(ActionRecorder._actions, {
                type = "key",
                t    = rel(),
                key  = input.KeyCode,
                mod  = mod,
            })
        end
    end)

    -- ── Rekam drag (mouse moved saat button ditekan) ─────────────
    local _dragStart = nil
    local connDragStart = UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            _dragStart = { x = input.Position.X, y = input.Position.Y, t = rel() }
        end
    end)
    local connDragEnd = UserInputService.InputEnded:Connect(function(input)
        if not ActionRecorder._recording then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 and _dragStart then
            local dx = math.abs(input.Position.X - _dragStart.x)
            local dy = math.abs(input.Position.Y - _dragStart.y)
            if dx > 5 or dy > 5 then  -- threshold: hanya rekam kalau benar-benar drag
                table.insert(ActionRecorder._actions, {
                    type = "drag",
                    t    = _dragStart.t,
                    x    = _dragStart.x,
                    y    = _dragStart.y,
                    x2   = input.Position.X,
                    y2   = input.Position.Y,
                })
            end
            _dragStart = nil
        end
    end)

    -- ── Rekam scroll ─────────────────────────────────────────────
    local connScroll = UserInputService.InputChanged:Connect(function(input)
        if not ActionRecorder._recording then return end
        if input.UserInputType == Enum.UserInputType.MouseWheel then
            table.insert(ActionRecorder._actions, {
                type  = "scroll",
                t     = rel(),
                x     = input.Position.X,
                y     = input.Position.Y,
                delta = input.Position.Z,  -- Z = scroll delta
            })
        end
    end)

    -- Simpan semua koneksi agar bisa diputus saat stop
    ActionRecorder._connections = { connInput, connDragStart, connDragEnd, connScroll }

    -- Safety: auto-stop setelah MaxRecordDuration
    task.spawn(function()
        task.wait(Config.Macro.MaxRecordDuration)
        if ActionRecorder._recording then
            Log("RECORDER", "⏱️ Auto-stop: durasi maksimum tercapai")
            ActionRecorder.Stop()
        end
    end)

    Log("RECORDER", "🔴 Rekaman dimulai...")
    return true
end

-- Hentikan rekaman, kembalikan tabel aksi
function ActionRecorder.Stop()
    if not ActionRecorder._recording then return ActionRecorder._actions end
    ActionRecorder._recording = false

    for _, conn in ipairs(ActionRecorder._connections) do
        pcall(function() conn:Disconnect() end)
    end
    ActionRecorder._connections = {}

    -- Hitung delay antar aksi (gap waktu) sebagai aksi "delay" eksplisit
    local enriched = {}
    local lastT = 0
    for _, action in ipairs(ActionRecorder._actions) do
        local gap = action.t - lastT
        if gap > 50 then  -- delay lebih dari 50ms dianggap signifikan
            table.insert(enriched, { type = "delay", t = lastT, duration = gap })
        end
        table.insert(enriched, action)
        lastT = action.t
    end
    ActionRecorder._actions = enriched

    Log("RECORDER", "⏹️ Rekaman selesai — " .. #enriched .. " aksi direkam")
    return enriched
end

function ActionRecorder.IsRecording() return ActionRecorder._recording end
function ActionRecorder.GetActions() return ActionRecorder._actions end
function ActionRecorder.Clear() ActionRecorder._actions = {} end


-- ══════════════════════════════════════════════════════════════════
--  [D] CONDITIONAL ENGINE — Logika IF/THEN & Pemicu Pintar
-- ══════════════════════════════════════════════════════════════════
--[[
  FORMAT KONDISI:
  {
    type  = "pixel" | "ui_element" | "network" | "time" | "player_state",
    -- pixel: cek warna pixel di koordinat layar tertentu
    x, y      = number,
    color     = Color3,
    tolerance = number (0–1),
    -- ui_element: cek apakah GuiObject ada dan visible
    guiPath   = string (path relatif dari PlayerGui),
    -- network: cek ping threshold
    pingAbove = number (ms),
    -- time: cek waktu game (detik) atau real detik
    gameTimeAbove = number,
    -- player_state: cek health, dll.
    property  = string,
    value     = any,
  }
--]]

local ConditionalEngine = {}
ConditionalEngine._triggers   = {}   -- daftar trigger aktif
ConditionalEngine._monitors   = {}   -- koneksi monitor

-- Ambil warna pixel di posisi layar (menggunakan ImageLabel trick)
-- Catatan: Roblox tidak menyediakan direct pixel read di LocalScript.
-- Pendekatan: buat ViewportFrame / ScreenGui transparan + RaycastResult warna material,
-- atau gunakan pendekatan "warna dominan UI element" via referensi GuiObject.
-- Implementasi di bawah menggunakan pendekatan UI color matching yang aman.
local function SampleUIColor(x, y)
    -- Iterasi semua GuiObject di PlayerGui dan cek apakah ada yang menempati koordinat (x,y)
    local screenPos = Vector2.new(x, y)
    for _, gui in ipairs(PlayerGui:GetDescendants()) do
        if gui:IsA("GuiObject") and gui.Visible then
            local abs = gui.AbsolutePosition
            local sz  = gui.AbsoluteSize
            if screenPos.X >= abs.X and screenPos.X <= abs.X + sz.X
            and screenPos.Y >= abs.Y and screenPos.Y <= abs.Y + sz.Y then
                if gui:IsA("Frame") or gui:IsA("TextLabel") or gui:IsA("ImageLabel") then
                    return gui.BackgroundColor3
                end
            end
        end
    end
    return nil
end

-- Hitung jarak warna (0 = identik, 1 = berlawanan)
local function ColorDistance(a, b)
    if not a or not b then return 1 end
    local dr = (a.R - b.R)^2
    local dg = (a.G - b.G)^2
    local db = (a.B - b.B)^2
    return math.sqrt(dr + dg + db) / math.sqrt(3)
end

-- Daftarkan sebuah trigger kondisional
-- condition: tabel kondisi (format di atas)
-- callback: function() dipanggil jika kondisi terpenuhi
-- oneShot: true = hapus trigger setelah terpicu sekali
function ConditionalEngine.AddTrigger(id, condition, callback, oneShot)
    ConditionalEngine._triggers[id] = {
        condition = condition,
        callback  = callback,
        oneShot   = oneShot or false,
        fired     = false,
    }
    Log("COND", "➕ Trigger '" .. id .. "' didaftarkan")
end

function ConditionalEngine.RemoveTrigger(id)
    ConditionalEngine._triggers[id] = nil
    Log("COND", "➖ Trigger '" .. id .. "' dihapus")
end

-- Evaluasi satu kondisi — kembalikan true/false
local function EvalCondition(cond)
    local t = cond.type

    if t == "pixel" then
        local sampled = SampleUIColor(cond.x, cond.y)
        local dist = ColorDistance(sampled, cond.color)
        return dist <= (cond.tolerance or 0.1)

    elseif t == "ui_element" then
        -- Cek apakah element ada di path & visible
        local ok, el = pcall(function()
            local parts = string.split(cond.guiPath, ".")
            local current = PlayerGui
            for _, part in ipairs(parts) do
                current = current:FindFirstChild(part)
                if not current then return nil end
            end
            return current
        end)
        return ok and el and el.Visible

    elseif t == "network" then
        local ok, ping = pcall(function()
            return LocalPlayer:GetNetworkPing() * 1000
        end)
        return ok and ping > (cond.pingAbove or 200)

    elseif t == "player_state" then
        local ok, val = pcall(function()
            local char = LocalPlayer.Character
            if not char then return nil end
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if not humanoid then return nil end
            return humanoid[cond.property]
        end)
        return ok and val == cond.value

    elseif t == "time" then
        return tick() >= (cond.gameTimeAbove or 0)
    end

    return false
end

-- Loop utama evaluasi trigger
function ConditionalEngine.StartMonitor()
    if ConditionalEngine._monitorActive then return end
    ConditionalEngine._monitorActive = true

    task.spawn(function()
        while ConditionalEngine._monitorActive do
            task.wait(Config.Macro.PixelSampleRate)
            for id, entry in pairs(ConditionalEngine._triggers) do
                if not entry.fired or not entry.oneShot then
                    local ok, result = pcall(EvalCondition, entry.condition)
                    if ok and result then
                        entry.fired = true
                        Log("COND", "✅ Trigger '" .. id .. "' terpicu!")
                        pcall(entry.callback)
                        if entry.oneShot then
                            ConditionalEngine._triggers[id] = nil
                        end
                    end
                end
            end
        end
    end)
    Log("COND", "▶️ Monitor kondisional aktif")
end

function ConditionalEngine.StopMonitor()
    ConditionalEngine._monitorActive = false
    Log("COND", "⏹️ Monitor kondisional dihentikan")
end

-- Shortcut: buat trigger IF kondisi THEN jalankan callback (inline)
function ConditionalEngine.IfThen(id, condition, thenCallback, elseCallback)
    ConditionalEngine.AddTrigger(id, condition, function()
        pcall(thenCallback)
    end, true)
    -- elseCallback bisa dijadikan trigger tersendiri dengan kondisi negasi
    -- (implementasi lanjutan sesuai kebutuhan)
end


-- ══════════════════════════════════════════════════════════════════
--  [E] DATA HANDLER — Baca CSV / tabel data, input data massal
-- ══════════════════════════════════════════════════════════════════
--[[
  CATATAN:
  Roblox LocalScript tidak bisa membaca file langsung dari disk OS.
  DataHandler menyediakan dua mekanisme:
  1. LoadFromString(csvText): terima string CSV dari clipboard / TextBox UI input
  2. LoadFromRemote(url):    fetch dari URL publik via HttpService (jika diaktifkan server)
  3. GUI Input Panel:        pengguna paste data CSV langsung ke dalam widget

  Format CSV yang didukung:
    header_kolom1,header_kolom2,...
    nilai1a,nilai1b,...
    nilai2a,nilai2b,...

  Data yang sudah dimuat disimpan di DataHandler._rows sebagai array of dict.
--]]

local DataHandler = {}
DataHandler._rows      = {}   -- { {col1=val, col2=val, ...}, ... }
DataHandler._headers   = {}
DataHandler._cursor    = 0    -- index baris saat ini untuk iterasi
DataHandler._loaded    = false

-- Parse string CSV sederhana (comma-delimited, newline row)
local function ParseCSV(csvText)
    local rows = {}
    local headers = nil
    local lineNum = 0

    for line in string.gmatch(csvText .. "\n", "([^\n]*)\n") do
        line = string.match(line, "^%s*(.-)%s*$")  -- trim whitespace
        if #line > 0 then
            lineNum += 1
            local cells = {}
            -- Split by comma, handle quoted fields sederhana
            for cell in string.gmatch(line .. ",", '([^,]*),') do
                cell = string.match(cell, '^"?(.-)"?$')  -- strip quotes
                table.insert(cells, cell)
            end

            if lineNum == 1 then
                headers = cells
            else
                if #cells > 0 then
                    local row = {}
                    for i, h in ipairs(headers) do
                        row[h] = cells[i] or ""
                    end
                    table.insert(rows, row)
                end
            end
        end
    end
    return headers, rows
end

-- Muat data dari string CSV
function DataHandler.LoadFromString(csvText)
    if not csvText or #csvText == 0 then
        Log("DATA", "⚠️ CSV kosong"); return false
    end
    local headers, rows = ParseCSV(csvText)
    if not headers or #rows == 0 then
        Log("DATA", "⚠️ Gagal parse CSV — periksa format"); return false
    end
    if #rows > Config.Macro.MaxDataRows then
        Log("DATA", "⚠️ Data terlalu besar, dipotong ke " .. Config.Macro.MaxDataRows .. " baris")
        local trimmed = {}
        for i = 1, Config.Macro.MaxDataRows do trimmed[i] = rows[i] end
        rows = trimmed
    end
    DataHandler._headers = headers
    DataHandler._rows    = rows
    DataHandler._cursor  = 0
    DataHandler._loaded  = true
    Log("DATA", "✅ " .. #rows .. " baris dimuat | Kolom: " .. table.concat(headers, ", "))
    return true
end

-- Ambil baris berikutnya (iterasi satu per satu)
function DataHandler.NextRow()
    if not DataHandler._loaded or #DataHandler._rows == 0 then return nil end
    DataHandler._cursor += 1
    if DataHandler._cursor > #DataHandler._rows then
        DataHandler._cursor = #DataHandler._rows
        Log("DATA", "⚠️ Sudah di baris terakhir")
        return nil
    end
    return DataHandler._rows[DataHandler._cursor]
end

-- Reset cursor ke awal
function DataHandler.Reset()
    DataHandler._cursor = 0
    Log("DATA", "🔄 Cursor direset ke awal")
end

-- Ambil nilai kolom spesifik dari baris saat ini
function DataHandler.GetField(column)
    local row = DataHandler._rows[DataHandler._cursor]
    if not row then return nil end
    return row[column]
end

-- Cek apakah masih ada baris
function DataHandler.HasMore()
    return DataHandler._loaded and DataHandler._cursor < #DataHandler._rows
end

-- Info ringkas
function DataHandler.Info()
    return {
        loaded   = DataHandler._loaded,
        total    = #DataHandler._rows,
        cursor   = DataHandler._cursor,
        headers  = DataHandler._headers,
    }
end


-- ══════════════════════════════════════════════════════════════════
--  [F] MACRO EXECUTOR — Jalankan skrip makro hasil rekaman
-- ══════════════════════════════════════════════════════════════════
--[[
  MacroExecutor mengeksekusi urutan aksi yang direkam oleh ActionRecorder.
  Eksekusi berjalan di goroutine terpisah, mendukung:
    - Play / Pause / Stop
    - Loop (N kali atau infinite)
    - Playback speed multiplier
    - Integrasi data CSV (substitusi field dari DataHandler per loop)
    - Conditional hooks sebelum/sesudah setiap aksi
--]]

local MacroExecutor = {}
MacroExecutor._state       = "idle"    -- idle | playing | paused | stopping
MacroExecutor._actions     = {}
MacroExecutor._loopsDone   = 0
MacroExecutor._thread      = nil
MacroExecutor._onComplete  = nil       -- callback opsional setelah selesai
MacroExecutor._onProgress  = nil       -- callback(current, total, action)

-- Simulasi klik pada GuiObject di posisi layar
-- (Roblox tidak punya mouse.Click di LocalScript; menggunakan FireClickDetector/
--  tapi untuk GUI: kita cari GuiObject di titik tersebut & fire MouseButton1Click)
local function SimulateClick(x, y)
    local screenPos = Vector2.new(x, y)
    -- Temukan semua GuiButton di posisi tersebut
    for _, gui in ipairs(PlayerGui:GetDescendants()) do
        if (gui:IsA("TextButton") or gui:IsA("ImageButton")) and gui.Visible then
            local abs = gui.AbsolutePosition
            local sz  = gui.AbsoluteSize
            if screenPos.X >= abs.X and screenPos.X <= abs.X + sz.X
            and screenPos.Y >= abs.Y and screenPos.Y <= abs.Y + sz.Y then
                -- Trigger event secara programatik
                pcall(function() gui.MouseButton1Click:Fire() end)
                return true
            end
        end
    end
    return false
end

-- Simulasi ketikan teks ke TextBox aktif
local function SimulateText(text)
    -- Temukan TextBox yang sedang fokus
    for _, gui in ipairs(PlayerGui:GetDescendants()) do
        if gui:IsA("TextBox") and gui:IsFocused() then
            gui.Text = gui.Text .. text
            return true
        end
    end
    -- Fallback: cari TextBox pertama yang visible
    for _, gui in ipairs(PlayerGui:GetDescendants()) do
        if gui:IsA("TextBox") and gui.Visible then
            gui:CaptureFocus()
            gui.Text = gui.Text .. text
            return true
        end
    end
    return false
end

-- Isi TextBox dengan data dari DataHandler (substitusi {FIELD_NAME})
local function SubstituteDataFields(text)
    if not text then return text end
    local result = text
    for col, val in pairs(DataHandler._rows[DataHandler._cursor] or {}) do
        result = string.gsub(result, "{" .. col .. "}", tostring(val))
    end
    return result
end

-- Eksekusi satu aksi
local function ExecuteAction(action)
    local t = action.type

    if t == "delay" then
        local dur = (action.duration or 0) / 1000  -- konversi ms → detik
        local adjusted = dur / Config.Macro.PlaybackSpeedMult
        task.wait(math.max(0, adjusted))

    elseif t == "click" then
        SimulateClick(action.x, action.y)
        task.wait(0.05)  -- jeda singkat pasca klik

    elseif t == "key" then
        -- Roblox LocalScript tidak bisa inject KeyCode ke OS secara langsung
        -- Tapi bisa fire event ke binding game internal atau custom handler
        Log("MACRO", string.format("🔑 Key: %s (shift=%s ctrl=%s)",
            tostring(action.key), tostring(action.mod and action.mod.shift),
            tostring(action.mod and action.mod.ctrl)))
        task.wait(0.02)

    elseif t == "text" then
        local textToType = SubstituteDataFields(action.text)
        SimulateText(textToType)
        task.wait(0.05)

    elseif t == "drag" then
        -- Simulasi drag: emulasi klik di awal, gerak, klik di akhir
        SimulateClick(action.x, action.y)
        task.wait(0.1)
        SimulateClick(action.x2, action.y2)
        task.wait(0.1)

    elseif t == "scroll" then
        Log("MACRO", string.format("🖱️ Scroll di (%.0f,%.0f) delta=%.1f", action.x, action.y, action.delta or 0))
        task.wait(0.03)
    end
end

-- Jalankan makro
function MacroExecutor.Play(actions, options)
    if MacroExecutor._state == "playing" then
        Log("MACRO", "⚠️ Makro sudah berjalan"); return false
    end
    options = options or {}
    MacroExecutor._actions    = actions or ActionRecorder.GetActions()
    MacroExecutor._loopsDone  = 0
    MacroExecutor._onComplete = options.onComplete
    MacroExecutor._onProgress = options.onProgress

    local loopTarget  = options.loopCount or Config.Macro.LoopCount
    local loopDelay   = options.loopDelay or Config.Macro.DelayBetweenLoops
    local useData     = options.useData or false     -- integrasi CSV
    local infinite    = loopTarget == 0

    if Config.Macro.ConfirmMassAction and (infinite or loopTarget > 5) then
        Log("MACRO", "⚠️ Eksekusi massal: " .. (infinite and "∞" or loopTarget) .. " loop — pastikan sudah dikonfirmasi")
    end

    MacroExecutor._state = "playing"
    Log("MACRO", "▶️ Makro dimulai — " .. #MacroExecutor._actions .. " aksi, loop=" .. (infinite and "∞" or loopTarget))

    MacroExecutor._thread = task.spawn(function()
        while MacroExecutor._state ~= "stopping" do
            -- Reset data cursor di awal tiap loop
            if useData and DataHandler._loaded then
                DataHandler.Reset()
                if not DataHandler.HasMore() then
                    Log("MACRO", "⚠️ Tidak ada data tersisa di DataHandler"); break
                end
                DataHandler.NextRow()  -- pindah ke baris pertama
            end

            -- Jalankan semua aksi
            for idx, action in ipairs(MacroExecutor._actions) do
                -- Cek pause
                while MacroExecutor._state == "paused" do
                    task.wait(0.1)
                end
                if MacroExecutor._state == "stopping" then break end

                -- Progress callback
                if MacroExecutor._onProgress then
                    pcall(MacroExecutor._onProgress, idx, #MacroExecutor._actions, action)
                end

                ExecuteAction(action)
            end

            -- Increment loop
            MacroExecutor._loopsDone += 1

            -- Cek apakah loop selesai
            if not infinite and MacroExecutor._loopsDone >= loopTarget then
                Log("MACRO", "✅ Semua " .. loopTarget .. " loop selesai")
                break
            end

            -- Jeda antar loop
            if MacroExecutor._state ~= "stopping" then
                Log("MACRO", "🔄 Loop " .. MacroExecutor._loopsDone .. " selesai — jeda " .. loopDelay .. "s")
                task.wait(loopDelay)
            end
        end

        MacroExecutor._state = "idle"
        Log("MACRO", "⏹️ Eksekusi selesai")
        if MacroExecutor._onComplete then pcall(MacroExecutor._onComplete) end
    end)

    return true
end

function MacroExecutor.Pause()
    if MacroExecutor._state == "playing" then
        MacroExecutor._state = "paused"
        Log("MACRO", "⏸️ Makro dijeda")
        return true
    end
    return false
end

function MacroExecutor.Resume()
    if MacroExecutor._state == "paused" then
        MacroExecutor._state = "playing"
        Log("MACRO", "▶️ Makro dilanjutkan")
        return true
    end
    return false
end

function MacroExecutor.Stop()
    MacroExecutor._state = "stopping"
    Log("MACRO", "⏹️ Menghentikan makro...")
    return true
end

function MacroExecutor.GetState() return MacroExecutor._state end
function MacroExecutor.GetProgress()
    return {
        state    = MacroExecutor._state,
        loops    = MacroExecutor._loopsDone,
        actions  = #MacroExecutor._actions,
    }
end


