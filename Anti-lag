    CameraFOV              = 70,

    ForceSmoothPlastic     = true,
    DisableDecals          = true,
    DisableShadows         = true,
    DisableBloom           = true,
    DisableBlur            = true,
    DisableSunRays         = true,
    DisableColorCorrection = true,
    DisableParticles       = true,
    DisableTrails          = true,
    DisableSmoke           = true,
    DisableFire            = true,
    DisableSparks          = true,
    KillLights             = true,

    -- Kabut
    DisableFog             = true,

    -- Polos NPC & Player
    PolosNPC               = true,
    PolosPlayers           = true,
    PolosColor             = nil,      -- nil = warna asli | Color3 = seragam
    PolosScanInterval      = 3.0,      -- detik antar re-scan NPC

    -- Throttle scan
    BatchSize              = 150,
    BatchDelay             = 0.03,
    WatcherQueueDelay      = 0.5,
    WatcherMaxPerTick      = 20,
}


