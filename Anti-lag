-- Sistem Draggable (Bisa Diseret)
local function MakeDraggable(obj)
	if not obj then return end
	local dragging, inputStart, startPos
	obj.InputBegan:Connect(function(input)
		if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and game:GetService("UserInputService"):GetFocusedTextBox() == nil then
			dragging = true inputStart = input.Position startPos = obj.Position
			input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
		end
	end)
	obj.InputChanged:Connect(function(input)
		if (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) and dragging then
			local delta = input.Position - inputStart
			obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		end
	end)
end
MakeDraggable(MenuToggle) 
MakeDraggable(MainWindow)

-- Eksekusi Penghancuran Skrip saat Tombol Pop-up IYA diklik
local Children = Pop:GetChildren()
local btnYes, btnNo
for _, child in pairs(Children) do
	if child:IsA("TextButton") then
		if child.Text == "IYA" then btnYes = child elseif child.Text == "TIDAK" then btnNo = child end
	end
end

if btnNo then btnNo.MouseButton1Click:Connect(function() Pop.Visible = false end) end
if btnYes then
	btnYes.MouseButton1Click:Connect(function()
		Pop.Visible = false
		if shared.B1 then shared.B1:Disconnect() end
		if shared.B2 then shared.B2:Disconnect() end
		shared.CurrentBoosterMode = 1 shared.Mode4Active = false
		pcall(function() game:GetService("StarterGui"):SetCoreGuiEnabled(Enum.CoreGuiType.All, true) end)
		
		for v, data in pairs(shared.OriginalBoosterData) do
			pcall(function()
				if v:IsA("BasePart") then v.Material = data.Material v.Color = data.Color v.Transparency = data.Transparency v.CastShadow = data.CastShadow
				elseif v:IsA("Sky") then v.Parent = data.Parent
				elseif v:IsA("Decal") or v:IsA("Texture") then v.Transparency = data.Transparency
				else v.Enabled = data.Enabled end
			end)
		end
		pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic end)
		game:GetService("Lighting").GlobalShadows = true game:GetService("Lighting").ExposureCompensation = 0
		if ScreenGui then ScreenGui:Destroy() print("Skrip Berhasil Dihapus Sempurna!") end
	end)
end

print("Seluruh Rangkaian Skrip Sukses Diperbaiki & Tamat Dimuat!")
