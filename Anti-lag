--            MODULE 13 — ULTIMATE HUD (FPS + PING + STATUS)
-- ══════════════════════════════════════════════════════════════════
local function M13_CreateHUD()
    local old = LocalPlayer.PlayerGui:FindFirstChild("UltraBoosterHUD")
    if old then old:Destroy() end

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name             = "UltraBoosterHUD"
    ScreenGui.ResetOnSpawn     = false
    ScreenGui.DisplayOrder     = 9999
    ScreenGui.IgnoreGuiInset   = true
    ScreenGui.Parent           = LocalPlayer.PlayerGui

    -- Main Frame
    local Frame = Instance.new("Frame")
    Frame.Size                 = UDim2.new(0, 185, 0, 105)
    Frame.Position             = Config.HUDPosition
    Frame.BackgroundColor3     = Color3.fromRGB(8, 8, 8)
    Frame.BackgroundTransparency = 0.3
    Frame.BorderSizePixel      = 0
    Frame.Parent               = ScreenGui

    Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 10)

    -- Border stroke
    local Stroke = Instance.new("UIStroke")
    Stroke.Color     = Color3.fromRGB(0, 210, 255)
    Stroke.Thickness = 1.5
    Stroke.Parent    = Frame

    -- Padding
    local Pad = Instance.new("UIPadding")
    Pad.PaddingLeft   = UDim.new(0, 8)
    Pad.PaddingRight  = UDim.new(0, 8)
    Pad.PaddingTop    = UDim.new(0, 6)
    Pad.Parent        = Frame

    -- Layout
    local Layout = Instance.new("UIListLayout")
    Layout.SortOrder  = Enum.SortOrder.LayoutOrder
    Layout.Padding    = UDim.new(0, 2)
    Layout.Parent     = Frame

    -- Helper buat label
    local function MakeLabel(text, color, order)
        local lbl = Instance.new("TextLabel")
        lbl.Size                = UDim2.new(1, 0, 0, 26)
        lbl.BackgroundTransparency = 1
        lbl.Text                = text
        lbl.TextColor3          = color or Color3.new(1,1,1)
        lbl.TextScaled          = true
        lbl.Font                = Enum.Font.GothamBold
        lbl.TextXAlignment      = Enum.TextXAlignment.Left
        lbl.LayoutOrder         = order or 1
        lbl.Parent              = Frame
        return lbl
    end

    local TitleLbl  = MakeLabel("⚡ ULTRA BOOSTER ON", Color3.fromRGB(0, 210, 255), 1)
    local FPSLbl    = MakeLabel("FPS  : --",           Color3.fromRGB(255, 255, 255), 2)
    local PingLbl   = MakeLabel("PING : --ms",         Color3.fromRGB(200, 200, 200), 3)
    local StatLbl   = MakeLabel("MODE : " .. (IsMobile() and "📱 MOBILE" or "🖥️ PC"), Color3.fromRGB(150,150,150), 4)

    -- FPS Counter
    local lastTime = tick()
    local frames   = 0

    RunService.RenderStepped:Connect(function()
        frames += 1
        local now = tick()
        if now - lastTime >= 0.5 then
            local fps = math.floor(frames / (now - lastTime))
            frames    = 0
            lastTime  = now

            FPSLbl.Text = "FPS  : " .. fps

            if fps >= 50 then
                FPSLbl.TextColor3 = Color3.fromRGB(0, 255, 100)
            elseif fps >= 30 then
                FPSLbl.TextColor3 = Color3.fromRGB(255, 200, 0)
            else
                FPSLbl.TextColor3 = Color3.fromRGB(255, 60, 60)
            end
        end
    end)

    -- Ping Counter
    if Config.ShowPing then
        task.spawn(function()
            while task.wait(2) do
                pcall(function()
                    local ping = math.floor(LocalPlayer:GetNetworkPing() * 1000)
                    PingLbl.Text = "PING : " .. ping .. "ms"

                    if ping < 100 then
                        PingLbl.TextColor3 = Color3.fromRGB(0, 255, 100)
                    elseif ping < 200 then
                        PingLbl.TextColor3 = Color3.fromRGB(255, 200, 0)
                    else
                        PingLbl.TextColor3 = Color3.fromRGB(255, 60, 60)
                    end
                end)
            end
        end)
    end

    Log("✅ [M13] HUD aktif — FPS + Ping + Status")
end

