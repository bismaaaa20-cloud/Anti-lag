-- Fungsi Pemrosesan Grafis Aset Game
local function SetAssetVisibility(obj, visible)
	pcall(function()
		if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Sparkles") or obj:IsA("Beam") then
			if not shared.OriginalBoosterData[obj] then shared.OriginalBoosterData[obj] = {Enabled = obj.Enabled} end
			obj.Enabled = visible
		elseif obj:IsA("Decal") or obj:IsA("Texture") then
			if not shared.OriginalBoosterData[obj] then shared.OriginalBoosterData[obj] = {Transparency = obj.Transparency} end
			obj.Transparency = visible and shared.OriginalBoosterData[obj].Transparency or 1
		elseif obj:IsA("Sky") then
			if not visible then 
				if obj.Parent ~= nil then shared.OriginalBoosterData[obj] = {Parent = obj.Parent} obj.Parent = nil end
			else 
				if shared.OriginalBoosterData[obj] and shared.OriginalBoosterData[obj].Parent then obj.Parent = shared.OriginalBoosterData[obj].Parent end 
			end
		end
	end)
end

local function CleanObject(object)
	local LocalPlayer = game:GetService("Players").LocalPlayer
	if not object:IsA("BasePart") or (LocalPlayer.Character and object:IsDescendantOf(LocalPlayer.Character)) then return end
	if not shared.OriginalBoosterData[object] then
		shared.OriginalBoosterData[object] = {
			Material = object.Material, Color = object.Color, Transparency = object.Transparency, CastShadow = object.CastShadow, TextureID = object:IsA("MeshPart") and object.TextureID or nil
		}
	end
	local mode = shared.CurrentBoosterMode
	if mode == 1 then
		object.Material = shared.OriginalBoosterData[object].Material object.Color = shared.OriginalBoosterData[object].Color object.Transparency = shared.OriginalBoosterData[object].Transparency object.CastShadow = shared.OriginalBoosterData[object].CastShadow
		if object:IsA("MeshPart") and shared.OriginalBoosterData[object].TextureID then object.TextureID = shared.OriginalBoosterData[object].TextureID end
	elseif mode == 2 then object.Material = Enum.Material.SmoothPlastic object.Color = Color3.fromRGB(255, 255, 255) object.Transparency = 0 object.CastShadow = false if object:IsA("MeshPart") then object.TextureID = "" end
	elseif mode == 3 then object.Transparency = 1 object.CastShadow = false end
end

function shared.ExecuteDeepCleanRefresh()
	local mode = shared.CurrentBoosterMode
	if shared.Mode4Active then
		BlackScreen.Visible = true
		pcall(function() game:GetService("StarterGui"):SetCoreGuiEnabled(Enum.CoreGuiType.All, false) end)
	else
		BlackScreen.Visible = false
		pcall(function() game:GetService("StarterGui"):SetCoreGuiEnabled(Enum.CoreGuiType.All, true) end)
	end
	pcall(function()
		if mode > 1 or shared.Mode4Active then settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 game:GetService("Lighting").GlobalShadows = false
		else settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic game:GetService("Lighting").GlobalShadows = true end
	end)
	local allObjects = game:GetService("Workspace"):GetDescendants()
	for i = 1, #allObjects do local v = allObjects[i] if v then SetAssetVisibility(v, (mode == 1 and not shared.Mode4Active)) CleanObject(v) end end
end

