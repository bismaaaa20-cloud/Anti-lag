    hudFrame.BorderSizePixel = 0
    Instance.new("UICorner", hudFrame).CornerRadius = UDim.new(0, 8)
    hudFrame.Parent = hudGui

    local fpsLbl = MkLabel(hudFrame, "FPS: --", UDim2.new(1,0,0.5,0), UDim2.new(0,0,0,0),
