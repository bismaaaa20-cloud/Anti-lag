local FPSBooster = {}

-- ── Render & Lighting ────────────────────────────────────────────
function FPSBooster.ApplyRenderAndLighting()
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)
    SafeSet(Camera, "FieldOfView", Config.CameraFOV)
    SafeSet(Lighting, "GlobalShadows", false)

    -- Hapus efek Lighting
    for _, fx in pairs(Lighting:GetChildren()) do
        pcall(function()
            if Config.DisableBloom           and IsType(fx, "BloomEffect")         then fx:Destroy()
            elseif Config.DisableBlur        and IsType(fx, "BlurEffect")          then fx:Destroy()
            elseif Config.DisableSunRays     and IsType(fx, "SunRaysEffect")       then fx:Destroy()
            elseif Config.DisableColorCorrection and IsType(fx, "ColorCorrectionEffect") then fx:Destroy()
            end
        end)
    end

    -- Hilangkan kabut klasik
    if Config.DisableFog then
        pcall(function()
            Lighting.FogStart = 100000
            Lighting.FogEnd   = 100000
        end)
        -- Hilangkan Atmosphere (kabut volumetrik modern)
        for _, child in pairs(Lighting:GetChildren()) do
            pcall(function()
                if IsType(child, "Atmosphere") then
                    child.Density = 0
                    child.Haze    = 0
                    child.Glare   = 0
                    child.Offset  = 0
                end
            end)
        end
        Log("FPS", "🌫️ Kabut (Fog + Atmosphere) dihilangkan")
    end

    Log("FPS", "✅ Render & Lighting applied")
end

-- ── Mobile Boost ─────────────────────────────────────────────────
function FPSBooster.MobileBoost()
    if not IsMobile() then
        Log("FPS", "🖥️ Mode PC terdeteksi")
        return
    end
    Log("FPS", "📱 Mode Mobile — boost ringan diterapkan")
    pcall(function()
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    end)
end

-- ── Optimasi satu object ─────────────────────────────────────────
function FPSBooster.OptimizeObject(obj)
    pcall(function()
        if IsType(obj, "BasePart") then
            if Config.DisableShadows    then obj.CastShadow = false end
            if Config.ForceSmoothPlastic then obj.Material = Enum.Material.SmoothPlastic end
            return
        end
        if Config.DisableDecals and (IsType(obj, "Decal") or IsType(obj, "Texture")) then
            obj.Transparency = 1; return
        end
        if Config.DisableParticles and IsType(obj, "ParticleEmitter") then obj.Enabled = false; return end
        if Config.DisableTrails    and IsType(obj, "Trail")           then obj.Enabled = false; return end
        if Config.DisableSmoke     and IsType(obj, "Smoke")           then obj.Enabled = false; return end
        if Config.DisableFire      and IsType(obj, "Fire")            then obj.Enabled = false; return end
        if Config.DisableSparks    and IsType(obj, "Sparkles")        then obj.Enabled = false; return end
        if Config.KillLights then
            if IsType(obj, "PointLight") or IsType(obj, "SpotLight") or IsType(obj, "SurfaceLight") then
                obj.Brightness = 0
            end
        end
    end)
end

-- ── Batch scan awal workspace ────────────────────────────────────
function FPSBooster.BatchScanWorkspace()
    local all = Workspace:GetDescendants()
    local total = #all
    Log("FPS", "🔍 Scan " .. total .. " object (batch mode, aman dari freeze)")
    for i = 1, total, Config.BatchSize do
        local batchEnd = math.min(i + Config.BatchSize - 1, total)
        for j = i, batchEnd do
            FPSBooster.OptimizeObject(all[j])
        end
        task.wait(Config.BatchDelay)
    end
    Log("FPS", "✅ Scan selesai: " .. total .. " object dioptimasi")
end

-- ── Realtime watcher (throttled) ─────────────────────────────────
function FPSBooster.StartThrottledWatcher()
    local watchQueue, queueSize = {}, 0

    Workspace.DescendantAdded:Connect(function(obj)
        if IsType(obj, "BasePart")       or IsType(obj, "ParticleEmitter")
        or IsType(obj, "Trail")          or IsType(obj, "Smoke")
        or IsType(obj, "Fire")           or IsType(obj, "Sparkles")
        or IsType(obj, "Decal")          or IsType(obj, "Texture")
        or IsType(obj, "PointLight")     or IsType(obj, "SpotLight") then
            queueSize += 1
            watchQueue[queueSize] = obj
        end
    end)

    task.spawn(function()
        while true do
            task.wait(Config.WatcherQueueDelay)
            local processed = 0
            while queueSize > 0 and processed < Config.WatcherMaxPerTick do
                local obj = watchQueue[queueSize]
                watchQueue[queueSize] = nil
                queueSize -= 1
                if obj and obj.Parent then
                    FPSBooster.OptimizeObject(obj)
                end
                processed += 1
            end
        end
    end)

    Log("FPS", "✅ Throttled watcher aktif")
end


